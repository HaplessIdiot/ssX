#define IHaveSubdirs
#define PassCDebugFlags

#ifndef NeedBerklib
#define NeedBerklib NO
#endif

#if NeedBerklib
BERKDIR = Xbsd
#endif

#if BuildXKBlib
XKBLIBDIR = xkbfile
#endif

#if BuildThreadStubLibrary
THRSTUBLIB = XThrStub
#endif

#if BuildExtraExtensionLibrary
EXEXTLIB = XExExt
#endif

#if !BuildServersOnly
LINTSUBDIRS = Xau Xdmcp $(THRSTUBLIB) X11 oldX ICE SM Xext $(EXEXTLIB) \
	     Xt Xmu Xaw XIE Xi Xtst FS PEX5 $(XKBLIBDIR)
#else
/* For ServersOnly */
LINTSUBDIRS = Xau Xdmcp $(XKBLIBDIR)
#endif
FONTSUBDIR = font

SUBDIRS = $(BERKDIR) xtrans $(LINTSUBDIRS) $(FONTSUBDIR)

MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))
MakeLintLibSubdirs($(LINTSUBDIRS))
MakeLintSubdirs($(LINTSUBDIRS),install.ln,install.ln)

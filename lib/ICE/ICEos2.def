	 IceGetInBufSize  @ 19
	 IceGetListenConnectionNumber  @ 20
	 IceGetListenConnectionString  @ 21
	 IceGetOutBufSize  @ 22
	 IceInitThreads  @ 23
	 IceLastReceivedSequenceNumber  @ 24
	 IceLastSentSequenceNumber  @ 25
	 IceListenForConnections  @ 26
	 IceLockAuthFile  @ 27

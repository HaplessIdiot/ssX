SRCS_SFNT     = sfnt.c
OBJS_SFNT     = sfnt.o

SRCS_CFF      = cff.c
OBJS_CFF      = cff.o

SRCS_PSNAMES  = psnames.c
OBJS_PSNAMES  = psnames.o

SRCS_PSAUX    = psaux.c
OBJS_PSAUX    = psaux.o

SRCS_TRUETYPE = truetype.c
OBJS_TRUETYPE = truetype.o


#ifndef SharedFreetypeRev
#define SharedFreetypeRev 6.0
#endif

FREETYPELIBSRC=$(TOP)/lib/freetype2
FREETYPE2ORIG=$(TOP)/extras/freetype2
SharedLibReferences(FREETYPE,freetype,$(FREETYPELIBSRC),SOFREETYPEREV,SharedFreetypeRev)

#define DoNormalLib	NO
#define DoSharedLib	YES
#define DoExtraLib	NO
#define DoDebugLib	NO
#define DoProfileLib	NO
#define HasSharedData	YES
#define LibName		freetype
#define SoRev		SOFREETYPEREV
#define LibHeaders	NO

#include <Threads.tmpl>

SRCDIR    = $(FREETYPE2ORIG)/src
BASE      = $(SRCDIR)/base

INCLUDES=-I$(FREETYPE2ORIG)/include -I$(FREETYPE2ORIG)/src

INCDIR   = $(FREETYPE2ORIG)/include/freetype

HEADERS= \

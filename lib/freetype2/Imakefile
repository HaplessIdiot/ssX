SRCS_RASTER   = raster.c
OBJS_RASTER   = raster.o

SRCS_SMOOTH   = smooth.c
OBJS_SMOOTH   = smooth.o

SRCS_WINFONTS = winfnt.c
OBJS_WINFONTS = winfnt.o


SRCS = $(SRCS_BASE) $(SRCS_AUTOHINT) $(SRCS_SFNT) $(SRCS_CFF) \

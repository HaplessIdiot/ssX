#include <Server.tmpl>

#if DoLoadableServer
XFMODSRC = speedomod.c
XFMODOBJ = speedomod.o
#endif

        INCLUDES = -I$(FONTINCSRC) -I../include -I$(SERVERSRC)/include -I$(XTOP)/include -I$(XF86OSSRC) -I$(XF86COMSRC)
         HEADERS = 
      SPEEDOSRCS = do_char.c do_trns.c out_bl2d.c out_blk.c $(XFMODSRC) \
		   out_scrn.c out_util.c reset.c set_spcs.c set_trns.c 
      SPEEDOOBJS = do_char.o do_trns.o out_bl2d.o out_blk.o $(XFMODOBJ) \
		   out_scrn.o out_util.o reset.o set_spcs.o set_trns.o

            SRCS = spfuncs.c spfile.c spinfo.c sperr.c spfont.c spglyph.c \
		spencode.c \
	    	$(SPEEDOSRCS)
            OBJS = spfuncs.o spfile.o spinfo.o sperr.o spfont.o spglyph.o \
		spencode.o \
		$(SPEEDOOBJS)

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalLintTarget($(SRCS))

DependTarget()

#if DoLoadableServer
NormalLibraryTarget(speedo,?*.o)
InstallDynamicModule(LibraryTargetName(speedo),$(MODULEDIR))
#endif

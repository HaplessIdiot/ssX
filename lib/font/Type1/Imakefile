#include <Server.tmpl>

#if DoLoadableServer
XFMODSRC = type1mod.c
XFMODOBJ = type1mod.o
INCLUDES = -I$(FONTINCSRC) -I../include -I$(XTOP)/include -I$(XF86COMSRC) -I$(SERVERSRC)/include
#else
INCLUDES = -I$(FONTINCSRC) -I../include
#endif

SRCS =          \
       arith.c         \
       curves.c        \
       fontfcn.c       \
       hints.c         \
       lines.c         \
       objects.c       \
       paths.c         \
       regions.c       \
       scanfont.c      \
       spaces.c        \
       t1funcs.c       \
       t1info.c        \
       t1io.c          \
       t1malloc.c      \
       t1snap.c        \
       t1stub.c       \
       token.c         \
       type1.c         \
       util.c		\
       $(XFMODSRC)

OBJS =          \
       arith.o         \
       curves.o        \
       fontfcn.o       \
       hints.o         \
       lines.o         \
       objects.o       \
       paths.o         \
       regions.o       \
       scanfont.o      \
       spaces.o        \
       t1funcs.o       \
       t1info.o        \
       t1io.o          \
       t1malloc.o      \
       t1snap.o        \
       t1stub.o       \
       token.o         \
       type1.o         \
       util.o		\
       $(XFMODOBJ)

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalLintTarget($(SRCS))

DependTarget()
#if DoLoadableServer
NormalLibraryTarget(type1,?*.o)
InstallDynamicModule(LibraryTargetName(type1),$(MODULEDIR))
#endif

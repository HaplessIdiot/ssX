XCOMM $XFree86: xc/lib/font/Imakefile,v 3.14 1998/09/06 04:46:54 dawes Exp $
#include <Server.tmpl>

#define	IHaveSubdirs

#if BuildFreeType
FREETYPEDIRS  = FreeType
FREETYPEOBJS  = FreeType/?*.o
FREETYPEDONES = FreeType/DONE
#endif

SUBDIRS = bitmap fontfile fc Speedo Type1 $(FREETYPEDIRS) util
OBJS = bitmap/?*.o fontfile/?*.o fc/?*.o Speedo/?*.o Type1/?*.o \
       $(FREETYPEOBJS) util/?*.o
DONES = bitmap/DONE fontfile/DONE fc/DONE Speedo/DONE Type1/DONE\
       $(FREETYPEDONES) util/DONE

#if DoLoadableServer
BASEDIRS = fontfile fc util
BASEOBJS = fontfile/?*.o fc/?*.o util/?*.o
BASEDONES = fontfile/DONE fc/DONE util/DONE
#endif

#if HasParallelMake
MakeMutex($(SUBDIRS) $(DONES))
#endif

#if HasGnuMake || HasBsdMake
$(DONES): $(SUBDIRS)
#endif

#undef _LinkBuildLibrary
#define _LinkBuildLibrary(lib) LinkBuildLibrary(lib)

#ifndef OS2Architecture
NormalDepLibraryTarget(font,$(SUBDIRS) $(DONES),$(OBJS))
#else
all:: DONE
	cp $(OBJS) .

NormalDepLibraryTarget(font,$(DONES),?*.o)
#endif

#if DoLoadableServer
#ifndef OS2Architecture
NormalDepLibraryTarget(fontbase,$(BASEDIRS) $(BASEDONES),$(BASEOBJS))
#else
all:: DONE
	mkdir baseobjs
	cp $(BASEOBJS) baseobjs

NormalDepLibraryTarget(fonts,$(BASEDONES),baseobjs/?*.o)
#endif
#endif

InstallLinkKitLibrary(font,$(LINKKITDIR)/lib)

ForceSubdirs($(SUBDIRS))

DependSubdirs($(SUBDIRS))

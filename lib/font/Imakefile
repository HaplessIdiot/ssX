XCOMM $XFree86: xc/lib/font/Imakefile,v 3.17 1999/01/11 09:39:26 dawes Exp $
#include <Server.tmpl>

#define	IHaveSubdirs

#ifndef SeparateSharedCompile
#define SeparateSharedCompile YES
#endif
#if NormalLibFont && SharedLibFont && SeparateSharedCompile
STATIC_OBJSDIR = unshared/
#endif

#ifdef SharedXfontReqs
REQUIREDLIBS = SharedXfontReqs
#endif

#if BuildFreeType
       FREETYPEDIRS = FreeType
 FREETYPESHAREDOBJS = FreeType/?*.o
 FREETYPESTATICOBJS = FreeType/$(STATIC_OBJSDIR)?*.o
  FREETYPEDEBUGOBJS = FreeType/debugger/?*.o
FREETYPEPROFILEOBJS = FreeType/profiled/?*.o
      FREETYPEDONES = FreeType/DONE
#endif
#if BuildXTT
            XTTDIRS = X-TrueType
#if XTTInLibFont
      XTTSHAREDOBJS = X-TrueType/?*.o
      XTTSTATICOBJS = X-TrueType/$(STATIC_OBJSDIR)?*.o
       XTTDEBUGOBJS = X-TrueType/debugger/?*.o
     XTTPROFILEOBJS = X-TrueType/profiled/?*.o
#endif
           XTTDONES = X-TrueType/DONE
#endif

       SUBDIRS = bitmap fontfile fc Speedo Type1 $(FREETYPEDIRS) \
		 $(XTTDIRS) util stubs
   SHARED_OBJS = bitmap/?*.o fontfile/?*.o fc/?*.o Speedo/?*.o Type1/?*.o \
		 $(FREETYPESHAREDOBJS) $(XTTSHAREDOBJS) util/?*.o
   STATIC_OBJS = bitmap/$(STATIC_OBJSDIR)?*.o fontfile/$(STATIC_OBJSDIR)?*.o \
		 fc/$(STATIC_OBJSDIR)?*.o Speedo/$(STATIC_OBJSDIR)?*.o \
		 Type1/$(STATIC_OBJSDIR)?*.o $(FREETYPESTATICOBJS) \
		 $(XTTSTATICOBJS) util/$(STATIC_OBJSDIR)?*.o
    DEBUG_OBJS = bitmap/debugger/?*.o fontfile/debugger/?*.o fc/debugger/?*.o \
		 Speedo/debugger/?*.o Type1/debugger/?*.o \
		 $(FREETYPEDEBUGOBJS) $(XTTDEBUGOBJS) \util/debugger/?*.o
  PROFILE_OBJS = bitmap/profiled/?*.o fontfile/profiled/?*.o fc/profiled/?*.o \
		 Speedo/profiled/?*.o Type1/profiled/?*.o \
		 $(FREETYPEPROFILEOBJS) $(XTTPROFILEOBJS) util/profiled/?*.o
         DONES = bitmap/DONE fontfile/DONE fc/DONE Speedo/DONE Type1/DONE \
		 $(FREETYPEDONES) $(XTTDONES) util/DONE

#if DoLoadableServer
      BASEDIRS = fontfile fc util
      BASEOBJS = fontfile/$(STATIC_OBJSDIR)?*.o fc/$(STATIC_OBJSDIR)?*.o \
		 util/$(STATIC_OBJSDIR)?*.o
     BASEDONES = fontfile/DONE fc/DONE util/DONE
#endif

#if HasParallelMake
MakeMutex($(SUBDIRS) $(DONES))
#endif

#if HasGnuMake || HasBsdMake
$(DONES): $(SUBDIRS)
#endif

#undef _LinkBuildLibrary
#define _LinkBuildLibrary(lib) LinkBuildLibrary(lib)

#if NormalLibFont
#ifndef OS2Architecture
NormalDepLibraryTarget(Xfont,$(SUBDIRS) $(DONES),$(STATIC_OBJS))
#else
all:: DONE
	cp $(STATIC_OBJS) .

NormalDepLibraryTarget(Xfont,$(DONES),?*.o)
#endif /* OS2Architecture */
InstallLibrary(Xfont,$(USRLIBDIR))
#if !SharedLibFont
InstallLinkKitLibrary(Xfont,$(LINKKITDIR)/lib)
#endif /* !SharedLibFont */
#endif /* NormalLibFont */

#if SharedLibFont
SharedDepLibraryTarget(Xfont,$(SOFONTREV),$(SUBDIRS) $(DONES),$(SHARED_OBJS),.,.)
InstallSharedLibrary(Xfont,$(SOFONTREV),$(SHLIBDIR))
#endif /* SharedLibFont */


#if DebugLibFont
#ifndef OS2Architecture
DebuggedDepLibraryTarget(Xfont,$(SUBDIRS) $(DONES),$(DEBUG_OBJS))
#else
all:: DONE
	rm -rf debugged
	mkdir debugged
	cp $(DEBUG_OBJS) debugged

DebuggedDepLibraryTarget(Xfont,$(DONES),?*.o)
#endif /* OS2Architecture */
InstallLibrary(Xfont_d,$(USRLIBDIR))
#endif /* DebugLibFont */

#if ProfileLibFont
#ifndef OS2Architecture
ProfiledDepLibraryTarget(Xfont,$(SUBDIRS) $(DONES),$(PROFILE_OBJS))
#else
all:: DONE
	rm -rf profiled
	mkdir profiled
	cp $(PROFILE_OBJS) profiled

ProfiledDepLibraryTarget(Xfont,$(DONES),?*.o)
#endif /* OS2Architecture */
InstallLibrary(Xfont_p,$(USRLIBDIR))
#endif /* ProfileLibFont */

#if DoLoadableServer
#ifndef OS2Architecture
NormalDepLibraryTarget(fontbase,$(BASEDIRS) $(BASEDONES),$(BASEOBJS))
#else
all:: DONE
	mkdir baseobjs
	cp $(BASEOBJS) baseobjs

NormalDepLibraryTarget(fontbase,$(BASEDONES),baseobjs/?*.o)
#endif
#endif


ForceSubdirs($(SUBDIRS))

DependSubdirs($(SUBDIRS))

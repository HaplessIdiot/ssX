#include <Server.tmpl>

#define IHaveSubdirs
SUBDIRS = lib

#if DoLoadableServer
XFMODSRC = freetypemod.c
XFMODOBJ = freetypemod.o
INCLUDES = -I$(FONTINCSRC) -I../include  -Ilib -I$(XF86COMSRC) -I$(XTOP)/include -I$(SERVERSRC)/include
#else
INCLUDES = -I$(FONTINCSRC) -I../include  -Ilib
#endif

SRCS = ftfuncs.c ftenc.c ftutil.c ftxcmap.c $(XFMODSRC)

OBJS = ftfuncs.o ftenc.o ftutil.o ftxcmap.o $(XFMODOBJ)

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalLintTarget($(SRCS))

DependTarget()

MakeSubdirs($(SUBDIRS))
ForceSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

#if DoLoadableServer
NormalLibraryTarget(freetype,?*.o lib/?*.o)
InstallDynamicModule(LibraryTargetName(freetype),$(MODULEDIR))
#endif


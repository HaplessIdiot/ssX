#include <Server.tmpl>

#define	IHaveSubdirs
SUBDIRS = lib

INCLUDES = -I$(FONTINCSRC) -I../include  -Ilib

SRCS = ftfuncs.c ftenc.c ftutil.c ftxcmap.c

OBJS = ftfuncs.o ftenc.o ftutil.o ftxcmap.o

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalLintTarget($(SRCS))

DependTarget()

MakeSubdirs($(SUBDIRS))
ForceSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

#include <Server.tmpl>

         HEADERS = 
#ifdef FontFormatDefines
     FORMAT_DEFS = FontFormatDefines
#endif
#if GzipFontCompression
       GZIP_DEFS = -DX_GZIP_FONT_COMPRESSION
#endif

#if DoLoadableServer
XFMODSRC = bitmapmod.c
XFMODOBJ = bitmapmod.o
INCLUDES = -I$(FONTINCSRC) -I../include -I$(SERVERSRC)/include -I$(XTOP)/include -I$(XF86COMSRC)
#else
INCLUDES = -I$(FONTINCSRC) -I../include
#endif

            SRCS = bdfread.c bdfutils.c bitmap.c bitmaputil.c bitscale.c \
		   bitmapfunc.c pcfread.c pcfwrite.c snfread.c \
		   fontink.c $(XFMODSRC)

            OBJS = bdfread.o bdfutils.o bitmap.o bitmaputil.o bitscale.o \
		   bitmapfunc.o pcfread.o pcfwrite.o snfread.o \
		   fontink.o $(XFMODOBJ)

SpecialCObjectRule(bitmapfunc,$(ICONFIGFILES),$(GZIP_DEFS))

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalLintTarget($(SRCS))

DependTarget()

#if DoLoadableServer
NormalLibraryTarget(bitmap,?*.o)
InstallDynamicModule(LibraryTargetName(bitmap),$(MODULEDIR))
#endif

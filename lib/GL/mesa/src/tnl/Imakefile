#ifdef i386Architecture
     ASM_SRCS =
     ASM_OBJS =
#if MesaUseMMX
     MMX_DEFS = -DUSE_MMX_ASM
#endif
#if MesaUse3DNow
   3DNOW_DEFS = -DUSE_3DNOW_ASM
#endif
#if MesaUseSSE
     SSE_DEFS = -DUSE_SSE_ASM
#endif

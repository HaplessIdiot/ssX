#define DoProfileLib ProfileLibGlx

#define IHaveSubdirs
#define PassCDebugFlags

#if GlxUseBuiltInDRIDriver
#if GlxBuiltInGamma
DRIVER += gamma
#endif
#if GlxBuiltInTdfx
DRIVER += tdfx
#endif

SUBDIRS = $(DRIVER)
#else
SUBDIRS += gamma
#if HasGlide3

XCOMM $PI: xc/lib/GL/Imakefile,v 1.9 1999/06/08 16:35:11 faith Exp $

#define IHaveSubdirs
#define PassCDebugFlags

#define DoNormalLib NormalLibGlx
#define DoSharedLib SharedLibGlx
#define DoExtraLib SharedLibGlx
#define DoDebugLib DebugLibGlx
#define DoProfileLib ProfileLibGlx

#if BuildXF86DRI
DRIDIRS = dri
#endif
SUBDIRS = glx $(DRIDIRS) mesa/src

#ifdef SharedGLReqs
REQUIREDLIBS = SharedGLReqs
#endif

MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

     LIBNAME = GL
     SOREV   = $(SOGLREV)

     GLXOBJS = glx/?*.o
    GLXUOBJS = glx/unshared/?*.o
    GLXDOBJS = glx/debugger/?*.o
    GLXPOBJS = glx/profiled/?*.o
    GLXDONES = glx/DONE

#if BuildXF86DRI
     DRIOBJS = dri/?*.o
    DRIUOBJS = dri/unshared/?*.o
    DRIDOBJS = dri/debugger/?*.o
    DRIPOBJS = dri/profiled/?*.o
    DRIDONES = dri/DONE

     DRMOBJS = dri/drm/?*.o
    DRMUOBJS = dri/drm/unshared/?*.o
    DRMDOBJS = dri/drm/debugger/?*.o
    DRMPOBJS = dri/drm/profiled/?*.o
    DRMDONES = dri/drm/DONE
#if !GlxUseSGISI
    MESAOBJS = mesa/src/?*.o mesa/src/X/?*.o
   MESAUOBJS = mesa/src/unshared/?*.o mesa/src/X/unshared/?*.o
   MESADOBJS = mesa/src/debugger/?*.o mesa/src/X/debugger/?*.o
   MESAPOBJS = mesa/src/profiled/?*.o mesa/src/X/profiled/?*.o
   MESADONES = mesa/src/DONE mesa/src/X/DONE

   GAMMAOBJS = mesa/src/drv/gamma/?*.o
  GAMMAUOBJS = mesa/src/drv/gamma/unshared/?*.o
  GAMMADOBJS = mesa/src/drv/gamma/debugger/?*.o
  GAMMAPOBJS = mesa/src/drv/gamma/profiled/?*.o
  GAMMADONES = mesa/src/drv/gamma/DONE
#endif
#endif

#ifdef OS2Architecture
        OBJS = $(LIBNAME).a
#else
        OBJS = $(GLXOBJS)  $(DRIOBJS)  $(DRMOBJS)  $(MESAOBJS)  $(GAMMAOBJS)
#endif
#if HasSharedLibraries
       UOBJS = $(GLXUOBJS) $(DRIUOBJS) $(DRMUOBJS) $(MESAUOBJS) $(GAMMAUOBJS)
#else
       UOBJS = $(OBJS)
#endif
       DOBJS = $(GLXDOBJS) $(DRIDOBJS) $(DRMDOBJS) $(MESADOBJS) $(GAMMADOBJS)
       POBJS = $(GLXPOBJS) $(DRIPOBJS) $(DRMPOBJS) $(MESAPOBJS) $(GAMMAPOBJS)
       DONES = $(GLXDONES) $(DRIDONES) $(DRMDONES) $(MESADONES) $(GAMMADONES)

#include <Library.tmpl>

#if NormalLibGlx
NormalDepLibraryTarget($(LIBNAME),$(SUBDIRS) $(DONES),$(UOBJS))
InstallLibrary($(LIBNAME),$(USRLIBDIR))
#endif
#if SharedLibGlx
SharedDepLibraryTarget($(LIBNAME),$(SOREV),$(SUBDIRS) $(DONES),$(OBJS),.,.)
InstallSharedLibrary($(LIBNAME),$(SOREV),$(SHLIBDIR))
#endif
#if DebugLibGlx
DebuggedDepLibraryTarget($(LIBNAME),$(SUBDIRS) $(DONES),$(DOBJS))
InstallLibrary($(LIBNAME)_d,$(USRLIBDIR))
#endif
#if ProfileLibGlx
ProfiledDepLibraryTarget($(LIBNAME),$(SUBDIRS) $(DONES),$(POBJS))
InstallLibrary($(LIBNAME)_p,$(USRLIBDIR))
#endif

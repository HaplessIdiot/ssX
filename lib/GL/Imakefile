#include <Threads.tmpl>

#define IHaveSubdirs

#define PassCDebugFlags

      GLXDIRS = GL

#if BuildXF86DRI && !GlxUseSGISI && \
	(!GlxBuiltInMesa || !defined(GlxDriverUsesMesa))
     MESADIRS = mesa/src
   OSMESADIRS = mesa/src/OSmesa
#endif

#if BuildXF86DRI && !GlxUseBuiltInDRIDriver
      DRIDIRS = dri mesa/dri
     MESADIRS = mesa/src
   DRIVERDIRS = mesa/src/drv
#endif

SUBDIRS = $(GLXDIRS) $(DRIDIRS) $(MESADIRS) $(OSMESADIRS) $(DRIVERDIRS)

MakeSubdirs($(SUBDIRS))

DependSubdirs($(SUBDIRS))


#endif

      DEFINES = $(ALLOC_DEFINES)
     INCLUDES = -I$(XLIBSRC) -I$(EXTINCSRC) -I.
         SRCS = xf86drm.c xf86drmHash.c xf86drmRandom.c xf86drmSL.c \

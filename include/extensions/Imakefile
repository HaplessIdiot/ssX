SCREENSAVERHEADERS = saver.h saverproto.h scrnsaver.h

#ifdef XFree86Version
XVGAHELPHEADERS = VGAHelp.h VGAHelpstr.h
#endif

#if BuildExtraExtensionLibrary
EXTRAHEADERS = $(SCREENSAVERHEADERS) $(XVGAHELPHEADERS)
#endif


HEADERS = Xext.h multibuf.h shape.h XShm.h MITMisc.h XI.h XInput.h XIproto.h \
	XTest.h xtestext1.h XIE.h XIEproto.h XIEprotost.h \
	sync.h XKB.h XKBproto.h XKBstr.h $(EXTRAHEADERS)

all::

BuildIncludes($(HEADERS),extensions,..)
InstallMultipleFlags($(HEADERS),$(INCDIR)/extensions,$(INSTINCFLAGS))

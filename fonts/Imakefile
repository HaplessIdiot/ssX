#define IHaveSubdirs
#define PassCDebugFlags CDEBUGFLAGS="$(CDEBUGFLAGS)"

#if BuildSpeedoFonts || BuildType1Fonts
SCALEDDIR = scaled
#endif

FONTDIRS = bdf $(SCALEDDIR)

#if BuildPexExt
PEXDIR = PEX
#endif

SUBDIRS = bdf $(SCALEDDIR) $(PEXDIR)

MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

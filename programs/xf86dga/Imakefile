        DEPLIBS = $(DEPXLIB)
LOCAL_LIBRARIES = $(XLIB)
           SRCS = dga.c
           OBJS = dga.o

AllTarget(ProgramTargetName(dga))

NormalProgramTarget(dga,$(OBJS),$(DEPLIBS),$(LOCAL_LIBRARIES),NullParameter)
InstallProgramWithFlags(dga,$(BINDIR),$(INSTUIDFLAGS))
DependTarget()

InstallManPage(dga,$(MANDIR))

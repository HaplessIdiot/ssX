INCLUDES=-I$(XFT1LIBSRC) $(FREETYPE2INCLUDES)
DEFINES=$(FREETYPE2DEFINES) $(RENDERDEFINES)
DEPLIBS=$(DEPXFTLIB) $(DEPXRENDERLIB) $(DEPXLIB)
#ifndef DarwinArchitecture
LOCAL_LIBRARIES=$(XFT1LIBSRC)/libXft.so.$(SOXFT1REV) \
		$(XRENDERLIB) $(XLIB) $(FONTCONFIGLIB) $(EXPATLIB) $(FREETYPE2LIB)
#else
LOCAL_LIBRARIES=$(XFT1LIBSRC)/libXft.$(SOXFT1REV).dylib \
		$(XRENDERLIB) $(XLIB) $(FONTCONFIGLIB) $(EXPATLIB) $(FREETYPE2LIB)
#endif
SRCS=xftcache.c
OBJS=xftcache.o

ComplexProgramTarget(xftcache)
LinkBuildBinary(ProgramTargetName(xftcache))


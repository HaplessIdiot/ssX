#define IHaveSubdirs

    DATAFILES = README amiga ataritt macintosh sony x68k xfree86 xfree98
      SUBDIRS = digital sgi sun

all::

MakeXkbDir($(LIBDIR)/xkb,keymap)
InstallMultiple($(DATAFILES),$(LIBDIR)/xkb/keymap)
DependSubdirs($(SUBDIRS))

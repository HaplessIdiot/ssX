       SRCS = xtrapddmi.c xtrapdi.c xtrapdiswp.c xtrapditbl.c xf86XTrapModule.c
       OBJS = xtrapddmi.o xtrapdi.o xtrapdiswp.o xtrapditbl.o xf86XTrapModule.o
     INCLUDES = -I.. -I../../include -I$(EXTINCSRC) -I$(XINCLUDESRC)


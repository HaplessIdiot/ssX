LintLibraryTarget(dri,$(SRCS))
NormalLintTarget($(SRCS))

DependTarget()

#ifdef IHaveSubdirs
MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))
#endif


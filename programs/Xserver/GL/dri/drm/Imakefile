#define IHaveModules
#include <Server.tmpl>

#if defined(LinuxArchitecture)
OS_SUBDIR = linux
#endif

LinkSourceFile(drmlib.c,../../../hw/xfree86/os-support/$(OS_SUBDIR)/drm)
LinkSourceFile(drm.h,../../../hw/xfree86/os-support/$(OS_SUBDIR)/drm)
LinkSourceFile(drmlib.h,../../../hw/xfree86/os-support/$(OS_SUBDIR)/drm)

     SRCS = drmlib.c
     OBJS = drmlib.o

     INCLUDES = -I.

#if DoLoadableServer
ModuleObjectRule()
SubdirLibraryRule($(OBJS))
#else
NormalLibraryTarget(drm,$(OBJS))
NormalLibraryObjectRule()
#endif

LintLibraryTarget(drm,$(SRCS))
NormalLintTarget($(SRCS))

DependTarget()

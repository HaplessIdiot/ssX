OBJS = ali_driver.o ali_bank.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I../../vga -I$(SERVERSRC)/include -I$(INCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions

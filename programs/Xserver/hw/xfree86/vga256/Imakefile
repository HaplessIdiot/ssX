#include <Server.tmpl>

#define IHaveSubdirs

#if BuildOldVga
OLDSUBDIRS = cfb.banked enhanced
OLDSRCS = cfb.banked/?*.c enhanced/?*.c
OLDOBJS = cfb.banked/?*.o enhanced/?*.o
OLDDONES = cfb.banked/DONE enhanced/DONE
#endif

SUBDIRS = $(OLDSUBDIRS) vga drivers vgainit

SRCS = vga/?*.c vgainit/?*.c

OBJS = vga/?*.o vgainit/?*.o

DONES = vga/DONE

INCLUDES = -Ivga -I$(XF86COMSRC) -I$(XF86OSSRC) -I$(SERVERSRC)/include \
           -I$(INCLUDESRC)

VGADRIVERS = XF86Vga256Drivers

NormalDepLibraryTarget(vga256,$(SUBDIRS) $(DONES),$(OBJS))
#if BuildOldVga
NormalDepLibraryTarget(oldvga256,$(OLDSUBDIRS) $(OLDDONES),$(OLDOBJS))
#endif

ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),confvga256.sh,$(VGADRIVERS))

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

InstallLinkKitLibrary(vga256,$(LINKKITDIR)/drivers)
InstallLinkKitNonExecFile(confvga256.sh,$(LINKKITDIR))

DependSubdirs($(SUBDIRS))

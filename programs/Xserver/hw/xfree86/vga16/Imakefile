XCOMM $XFree86: xc/programs/Xserver/hw/xfree86/vga16/Imakefile,v 3.15 1997/03/12 06:21:31 hohndel Exp $


#define IHaveModules
#include <Server.tmpl>

#define IHaveSubdirs

#if ! DoLoadableServer
MISC = misc
#endif

SUBDIRS = ibm mfb $(MISC)

SRCS = ibm/?*.c mfb/?*.c

OBJS = ibm/?*.o mfb/?*.o

DONES = ibm/DONE mfb/DONE

INCLUDES = -I../vga256/vga -I$(XF86COMSRC) -I$(XF86OSSRC) \
	   -I$(SERVERSRC)/include -I$(XINCLUDESRC)

VGA16DRIVERS = XF86Vga16Drivers

#if HasParallelMake
MakeMutex($(SUBDIRS) $(OBJS) $(DONES))
#endif

#if HasGnuMake
$(DONES): $(SUBDIRS)
#endif

#if ! DoLoadableServer
ConfigTargetNoDepend(vga16Conf,$(ICONFIGFILES),cvga16.SHsuf,$(VGA16DRIVERS))
#endif

#ifdef OS2Architecture
all:: DONE
	cp $(OBJS) .

NormalDepLibraryTarget(vga16,$(DONES),?*.o)
#else
NormalDepLibraryTarget(vga16,$(SUBDIRS) $(DONES),$(OBJS))
#endif

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

InstallLinkKitLibrary(vga16,$(LINKKITDIR)/drivers)

#if DoLoadableServer
InstallDynamicModule(LibraryTargetName(vga16),$(MODULEDIR))
#endif

DependSubdirs($(SUBDIRS))

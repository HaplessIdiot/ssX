ObjectFromSpecialSource(mfbbltG,mfbblt,-DMROP=0)

ObjectFromSpecialSource(mfbtileC,mfbtile,-DMROP=Mcopy)

ObjectFromSpecialSource(mfbtileG,mfbtile,-DMROP=0)


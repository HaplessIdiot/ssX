XCOMM $XFree86$

#include <Server.tmpl>

SRCS = oak_driver.c oak_bank.s

OBJS = oak_driver.o oak_bank.o

#if XF86LinkKit
VGA256DIR = $(XF86SRC)/vga256
INCLUDES = -I. -I$(SERVERSRC)/include -I$(XF86SRC)
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(XF86SRC)/vga256/vga -I$(SERVERSRC)/include -I$(INCLUDESRC)
VGA256DIR = $(XF86SRC)/vga256/drivers
#endif

DEFINES = -DXF86VGA16

NormalLibraryObjectRule()

NormalRelocatableTarget(oak_drv, $(OBJS))

ObjectFromSpecialSource(oak_driver,$(VGA256DIR)/oak/oak_driver,/**/)
ObjectFromSpecialAsmSource(oak_bank,$(VGA256DIR)/oak/oak_bank,/**/)

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/vga16/oak)

DependTarget()

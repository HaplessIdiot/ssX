#ifndef OS2Architecture
SRCS = */?*.c 

OBJS = */?*_4bpp.o 
#else
SRCS = ati/?*.c cl64xx/?*.c et3000/?*.c et4000/?*.c generic/?*.c \
       ncr77c22/?*.c oak/?*.c tvga8900/?*.c sis/?*.c

OBJS = ati/?*_4bpp.o cl64xx/?*_4bpp.o et3000/?*_4bpp.o et4000/?*_4bpp.o \
       generic/?*_4bpp.o ncr77c22/?*_4bpp.o oak/?*_4bpp.o tvga8900/?*_4bpp.o \
       sis/?*_4bpp.o
#endif

#if MakeHasPosixVariableSubstitutions
DONES=$(SUBDIRS:%=%/DONE)
NormalDepLibraryTarget(driver16,$(SUBDIRS) $(DONES),$(OBJS))
#else
NormalDepLibraryTarget(driver16,$(SUBDIRS),$(OBJS))
#endif

NormalLibraryObjectRule()


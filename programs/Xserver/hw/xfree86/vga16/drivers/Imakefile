#include <Server.tmpl>
#define IHaveSubdirs

SUBDIRS = XF86Vga16Drivers

SRCS = */?*.c 

OBJS = */?*_drv.o 

all:: libdriver16.a

NormalLibraryObjectRule()

NamedMakeSubdirs(subdirs,$(SUBDIRS))

InstallLinkKitLibrary(driver16,$(LINKKITDIR)/drivers)

NormalDepLibraryTarget(driver16,subdirs,$(OBJS))

DependSubdirs($(SUBDIRS))

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/vga16)

#if XF86LinkKit
#include <LinkKit.tmpl>
#endif

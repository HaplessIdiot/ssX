#include <Server.tmpl>

SRCS = cl_driver.c cl_bank.s

OBJS = cl_driver.o cl_bank.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I../../../vga256/vga -I$(SERVERSRC)/include -I$(INCLUDESRC)
#endif

DEFINES = -DXF86VGA16

NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(cl6420_drv,$(OBJS))

LinkSourceFile(cl_driver.c,$(VGADRIVERSRC)/cl6420)
LinkSourceFile(cl_bank.s,$(VGADRIVERSRC)/cl6420)

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/vga16/cl6420)

DependTarget()

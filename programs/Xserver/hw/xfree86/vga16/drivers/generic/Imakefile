#include <Server.tmpl>

SRCS = gen_driver.c

OBJS = gen_driver.o

#if XF86LinkKit
VGA2DIR = ../../vga2
INCLUDES = -I. -I../../../include -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I../../../vga256/vga -I$(SERVERSRC)/include -I$(INCLUDESRC)
VGA2DIR = ../../../vga2/drivers
#endif

DEFINES = -DXF86VGA16

NormalLibraryObjectRule()

NormalRelocatableTarget(gen_drv, $(OBJS))

LinkSourceFile(gen_driver.c,$(VGA2DIR)/generic)

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/vga16/generic)

DependTarget()


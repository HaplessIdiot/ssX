XCOMM $XFree86$

XCOMM CDEBUGFLAGS=-g -Wall -ansi -pedantic

SRCS	=\
	accessx.c\
	card-cfg.c\
	cards.c\
	config.c\
	interface.c\
	keyboard-cfg.c\
	monitor-cfg.c\
	mouse-cfg.c\
	options.c\
	screen-cfg.c\
	screen.c\
	startx.c\
	xf86config.c

OBJS	=\
	accessx.o\
	cards.o\
	config.o\
	card-cfg.o\
	interface.o\
	keyboard-cfg.o\
	monitor-cfg.o\
	mouse-cfg.o\
	options.o\
	screen-cfg.o\
	screen.o\
	startx.o\
	xf86config.o

PROG	= xf86cfg

XBMPICS =\
	card.xbm\
	keyboard.xbm\
	monitor.xbm\
	mouse.xbm

XPMPICS =\
	card.xpm\
	computer.xpm\
	keyboard.xpm\
	monitor.xpm\
	mouse.xpm

all	:: $(PROG)

LOCAL_LIBRARIES = $(XAWLIB) $(XMULIB) $(XTOOLLIB) $(XLIB) \
		  $(XKBUILIB) $(XKBFILELIB) -lxf86config -lXxf86misc -lm

NormalProgramTarget($(PROG),$(OBJS),,$(LOCAL_LIBRARIES),)
InstallProgramWithFlags($(PROG),$(BINDIR),NullParameter)
InstallMultipleDestFlags(install,$(XBMPICS),$(INCDIR)/X11/bitmaps,$(INSTINCFLAGS))
InstallMultipleDestFlags(install,$(XPMPICS),$(INCDIR)/X11/pixmaps,$(INSTINCFLAGS))
InstallAppDefaults(XF86Cfg)

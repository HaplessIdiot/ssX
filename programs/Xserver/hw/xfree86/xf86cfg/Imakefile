XCOMM $XFree86: xc/programs/Xserver/hw/xfree86/xf86cfg/Imakefile,v 1.1 2000/04/04 22:36:56 dawes Exp $

XCOMM CDEBUGFLAGS=-g -Wall -ansi -pedantic

SRCS	=\
	accessx.c\
	card-cfg.c\
	cards.c\
	config.c\
	interface.c\
	keyboard-cfg.c\
	monitor-cfg.c\
	mouse-cfg.c\
	options.c\
	screen-cfg.c\
	screen.c\
	startx.c\
	xf86config.c

OBJS	=\
	accessx.o\
	cards.o\
	config.o\
	card-cfg.o\
	interface.o\
	keyboard-cfg.o\
	monitor-cfg.o\
	mouse-cfg.o\
	options.o\
	screen-cfg.o\
	screen.o\
	startx.o\
	xf86config.o

PROG	= xf86cfg

XBMPICS =\
	card.xbm\
	keyboard.xbm\
	monitor.xbm\
	mouse.xbm

XPMPICS =\
	card.xpm\
	computer.xpm\
	keyboard.xpm\
	monitor.xpm\
	mouse.xpm

AllTarget(ProgramTargetName($(PROG)))

LOCAL_LIBRARIES = $(XKBUILIB) $(XKBFILELIB) -lxf86config -lXxf86misc \
		  $(XAWLIB) $(XMULIB) $(XTOOLLIB) $(XLIB) -lm

NormalProgramTarget($(PROG),$(OBJS),,$(LOCAL_LIBRARIES),)
InstallProgramWithFlags($(PROG),$(BINDIR),NullParameter)
InstallMultipleFlags($(XBMPICS),$(INCDIR)/X11/bitmaps,$(INSTINCFLAGS))
InstallMultipleFlags($(XPMPICS),$(INCDIR)/X11/pixmaps,$(INSTINCFLAGS))
InstallAppDefaults(XF86Cfg)

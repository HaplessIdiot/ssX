# if BuildDynamicLoading
SpecialObjectRule(xf86Dl.o,xf86Dl.c,$(MODULEDEFINES))
#  if JoystickSupport
SpecialObjectRule(xf86Jstk.o,xf86Jstk.c,$(SHARED_CFLAGS))

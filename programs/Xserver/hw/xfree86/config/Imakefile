#include <Server.tmpl>

#define UseDBMalloc	NO

#if UseDBMalloc
SYS_LIBRARIES=-ldbmalloc
DBMALLOCDEFINE=-DDBMALLOC
#endif

XCONFIGFILE = XConfigFile
XCONFIGDIR = XConfigDir

INCLUDES = -I. -I$(XF86OSSRC)

HEADERS = xf86Parser.h xf86Optrec.h xf86Symtabs.h

SRCS = Device.c Files.c Flags.c Keyboard.c Layout.c Module.c \
	Monitor.c Pointer.c Screen.c Vendor.c read.c scan.c write.c
OBJS = Device.o Files.o Flags.o Keyboard.o Layout.o Module.o \
	Monitor.o Pointer.o Screen.o Vendor.o read.o scan.o write.o

CONFIG_DEFINES = -DXCONFIGDIR=\"$(XCONFIGDIR)\" -DXCONFIGFILE=\"$(XCONFIGFILE)\"

SpecialObjectRule(scan.o,scan.c,$(CONFIG_DEFINES) $(MODULEDEFINES) $(EXT_DEFINES))

NormalProgramTarget(cpconfig,cpconfig.o $(OBJS),NullParameter,NullParameter,NullParameter)

NormalLibraryTarget(xf86config,$(OBJS))
BuildIncludesTop($(HEADERS))
InstallLinkKitLibrary(xf86config,$(LINKKITDIR)/drivers)

AllTarget(ProgramTargetName(cpconfig))
DependTarget()

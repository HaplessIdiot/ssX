InstallLinkKitNonExecFile(cir_textbltc.c,$(LINKKITDIR)/drivers/svga/cirrus)
InstallLinkKitNonExecFile(cir_spanc.c,$(LINKKITDIR)/drivers/svga/cirrus)
#endif
InstallLinkKitNonExecFile(cir_colexp.c,$(LINKKITDIR)/drivers/svga/cirrus)

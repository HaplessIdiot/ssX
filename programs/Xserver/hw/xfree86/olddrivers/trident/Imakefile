#define IHaveModules
#include <Server.tmpl>

#ifdef i386Architecture
TRIDENTSRCS = trident_bank.s
TRIDENTOBJS = trident_bank.o
#else
TRIDENTSRCS = trident_bank.c
TRIDENTOBJS = trident_bank.o
#endif

SRCS = trident_driver.c $(TRIDENTSRCS) tgui_curs.c tgui_accel.c tguimaccel.c \
       tgui_oldacl.c tguimoldacl.c

OBJS = trident_driver.o $(TRIDENTOBJS) tgui_curs.o tgui_accel.o tguimaccel.o \
       tgui_oldacl.o tguimoldacl.o

DEFINES = -DPSZ=8

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I$(XF86SRC)/vga256/vga -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/cfb \
           -I../../xaa -I$(FONTINCSRC) \
           -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(trident_drv,$(OBJS))

#ifdef i386Architecture
ObjectFromSpecialAsmSource(trident_bank,bank,NullParameter)
#else
ObjectFromSpecialSource(trident_bank,bankc,NullParameter)
#endif

ObjectFromSpecialSource(tguimaccel, tgui_accel, -DTRIDENT_MMIO)
ObjectFromSpecialSource(tguimoldacl, tgui_oldacl, -DTRIDENT_MMIO)

InstallLinkKitNonExecFile(trident_driver.c,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(trident_driver.h,$(LINKKITDIR)/drivers/svga/trident)
#ifdef i386Architecture
InstallLinkKitNonExecFile(bank.s,$(LINKKITDIR)/drivers/svga/trident)
#else
InstallLinkKitNonExecFile(bankc.c,$(LINKKITDIR)/drivers/svga/trident)
#endif
InstallLinkKitNonExecFile(tgui_curs.c,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(tgui_drv.h,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(tgui_ger.h,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(tgui_mmio.h,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(tgui_accel.c,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(tgui_oldacl.c,$(LINKKITDIR)/drivers/svga/trident)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/trident)

#if DoLoadableServer
InstallDynamicModule(trident_drv.o,$(MODULEDIR))
#endif

DependTarget()

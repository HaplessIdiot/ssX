#define IHaveModules
#include <Server.tmpl>

#ifdef ATIDriverCCOptions
CCOPTIONS = ATIDriverCCOptions
#endif

SRCS = ati_driver.c ati_bank.s

OBJS = ati_driver.o ati_bank.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) -I$(XF86SRC) \
           -I$(XF86SRC)/vga256/vga -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if XF86Vga2Banked
DEFINES = -DBANKEDMONOVGA
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(ati_drv,$(OBJS))

ObjectFromSpecialAsmSource(ati_bank,bank,NullParameter)

InstallLinkKitNonExecFile(ati_driver.c,$(LINKKITDIR)/drivers/svga/ati)
InstallLinkKitNonExecFile(bank.s,$(LINKKITDIR)/drivers/svga/ati)
InstallLinkKitNonExecFile(regati.h,$(LINKKITDIR)/drivers/svga/ati)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/ati)

#if DoLoadableServer
InstallDynamicModule(ati_drv.o,$(MODULEDIR))
#endif

DependTarget()


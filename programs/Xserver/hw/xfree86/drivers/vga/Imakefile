#define IHaveModules
#include <Server.tmpl>

SRCS = generic.c

OBJS = generic.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(SERVERSRC)/cfb -I$(XF86SRC)/xf4bpp -I$(XF86SRC)/xf1bpp \
	   -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(XF86SRC)/vgahw \
	   -I$(XF86COMSRC) -I$(XF86OSSRC) \
	   -I$(SERVERSRC)/include -I$(FONTINCSRC) -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

ModuleObjectRule()

ObjectModuleTarget(vga,$(OBJS))

InstallLinkKitNonExecFile(generic.c,$(LINKKITDIR)/drivers/svga/vga)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/vga)

InstallObjectModule(vga,$(MODULEDIR))

DependTarget()


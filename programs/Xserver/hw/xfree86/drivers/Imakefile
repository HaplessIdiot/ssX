#else
OBJS = al2101/?*.o mx/?*.o oak/?*.o realtek/?*.o sis/?*.o trident/?*.o \
	ali/?*.o apm/?*.o apollo/?*.o ark/?*.o ati/?*.o chips/?*.o \
	cirrus/?*.o cl64xx/?*.o compaq/?*.o et3000/?*.o glint/?*.o \
	gvga/?*.o hercules/?*.o hgc1280/?*.o mga/?*.o ncr/?*.o \
	nv/?*.o s3/?*.o sigma/?*.o tseng/?*.o vga/?*.o video7/?*.o wd/?*.o 

#endif

#if 0
MakeSubdirs($(SUBDIRS))
#endif

#if MakeHasPosixVariableSubstitutions
DONES = $(SUBDIRS:%=%/DONE)
#if HasGnuMake || HasBsdMake
$(DONES): $(SUBDIRS)
#endif
NormalDepLibraryTarget(driver,$(SUBDIRS) $(DONES),$(OBJS))
#else
NormalDepLibraryTarget(driver,$(SUBDIRS),$(OBJS))
#endif

NormalLibraryObjectRule()

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/)


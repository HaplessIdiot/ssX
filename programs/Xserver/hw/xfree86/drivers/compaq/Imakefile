#define IHaveModuless
#include <Server.tmpl>

SRCS = cpq_driver.c cpq_bank.s

OBJS = cpq_driver.o cpq_bank.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(XF86SRC)/vga256/vga -I$(SERVERSRC)/include  -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(cpq_drv,$(OBJS))

InstallLinkKitNonExecFile(cpq_driver.c,$(LINKKITDIR)/drivers/svga/compaq)
InstallLinkKitNonExecFile(cpq_bank.s,$(LINKKITDIR)/drivers/svga/compaq)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/compaq)

DependTarget()


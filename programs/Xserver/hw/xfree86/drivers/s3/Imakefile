LinkSourceFile(s3ELSA.c,LinkDirectory)
LinkSourceFile(s3ramdacs.c,LinkDirectory)
LinkSourceFile(Ti3026Curs.c,LinkDirectory)
LinkSourceFile(s3TiCursor.c,LinkDirectory)
LinkSourceFile(s3init.c,LinkDirectory)
LinkSourceFile(s3fbinit.c,LinkDirectory)
LinkSourceFile(s3save.c,LinkDirectory)
LinkSourceFile(s3misc.c,LinkDirectory)
LinkSourceFile(s3accel.c,LinkDirectory)
LinkSourceFile(s3cursor.c,LinkDirectory)
LinkSourceFile(IBMRGBCurs.c,LinkDirectory)
LinkSourceFile(s3bank.s,LinkDirectory)
LinkSourceFile(s3.h,LinkDirectory)
LinkSourceFile(s3Bt485.h,LinkDirectory)
LinkSourceFile(s3ELSA.h,LinkDirectory)
LinkSourceFile(s3reg.h,LinkDirectory)
LinkSourceFile(newmmio.h,LinkDirectory)

#endif	/* LinkDirectory */

#if DoLoadableServer
#ifdef S3_NEWMMIO
 InstallDynamicModule(s3_newmmio_drv.o,$(MODULEDIR))
#endif
#ifdef S3_GENERIC
 InstallDynamicModule(s3_pio_drv.o,$(MODULEDIR))
#endif

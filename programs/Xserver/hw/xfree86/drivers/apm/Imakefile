XCOMM $XFree86$

#define IHaveModules
#include <Server.tmpl>

SRCS = apm_accel.c apm_cursor.c apm_driver.c apm_i2c.c
                   
OBJS = apm_accel.o apm_cursor.o apm_driver.o apm_i2c.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb  -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb  -I$(XF86SRC)/xaa \
           -I$(XF86SRC)/xf1bpp -I$(XF86SRC)/xf4bpp \
           -I$(XF86SRC)/vgahw  -I$(XF86SRC)/ramdac \
	   -I$(XF86SRC)/i2c -I$(XF86SRC)/ddc \
           -I$(SERVERSRC)/include -I$(XINCLUDESRC) -I$(FONTINCSRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

ModuleObjectRule()

ObjectModuleTarget(apm,$(OBJS))

/* XXX Is this needed? */
ObjectFromSpecialSource(apm_accel24, apm_accel, -DPSZ=24)

InstallLinkKitNonExecFile(apm.h,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_accel.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_accel24.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_cursor.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_driver.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_funcs.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_i2c.c,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(apm_regs.h,$(LINKKITDIR)/drivers/apm)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/apm)

InstallObjectModule(apm,$(MODULEDIR),drivers)

DependTarget()


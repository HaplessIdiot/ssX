#define IHaveModules
#include <Server.tmpl>

SRCS = tseng_driver.c tseng_accel.c tseng_bank.s tseng_acl.c tseng_ramdac.c \
       tseng_clock.c tseng_cursor.c tseng_colexp.c tseng_dpms.c

OBJS = tseng_driver.o tseng_accel.o tseng_bank.o tseng_acl.o tseng_ramdac.o \
       tseng_clock.o tseng_cursor.o tseng_colexp.o tseng_dpms.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../.. -I../../../xaa
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/cfb -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(XF86SRC)/vga256/vga -I$(XF86SRC)/xaa -I$(SERVERSRC)/include \
           -I$(XINCLUDESRC) -I$(FONTINCSRC)
#endif

DEFINES = -DPSZ=8

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(tseng_drv, $(OBJS))

ObjectFromSpecialAsmSource(tseng_bank,bank,NullParameter)

InstallLinkKitNonExecFile(tseng_driver.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_accel.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_acl.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_acl.h,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_inline.h,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_colexp.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_colexp.h,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_ramdac.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_clock.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng.h,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(bank.s,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_cursor.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_cursor.h,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(tseng_dpms.c,$(LINKKITDIR)/drivers/svga/tseng)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/tseng)

#if DoLoadableServer
InstallDynamicModule(tseng_drv.o,$(MODULEDIR))
#endif

DependTarget()


#define IHaveModules
#include <Server.tmpl>

SRCS = cir_driver.c CirrusClk.c cir_xaa.c cir_hwcurs.c cir_dga.c cir_i2c.c lg_driver.c
OBJS = cir_driver.o CirrusClk.o cir_xaa.o cir_hwcurs.o cir_dga.o cir_i2c.o lg_driver.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86OSSRC) \
           -I$(XF86SRC)/xf4bpp -I$(XF86SRC)/xf1bpp \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/xaa \
           -I$(XF86SRC)/ramdac -I$(XF86SRC)/i2c -I$(XF86SRC)/vgahw \
           -I$(FONTINCSRC) -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

ModuleObjectRule()

ObjectModuleTarget(cirrus,$(OBJS))

#if 0
InstallLinkKitNonExecFile(cir.h,$(LINKKITDIR)/drivers/svga/cir)
InstallLinkKitNonExecFile(cir_driver.c,$(LINKKITDIR)/drivers/svga/cir)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/cir)
#endif

InstallObjectModule(cirrus,$(MODULEDIR))

DependTarget()

#define IHaveModules
#include <Server.tmpl>

SRCS = trident_driver.c tridentramdac.c trident_dac.c tridenthelper.c \
       trident_accel.c
OBJS = trident_driver.o tridentramdac.o trident_dac.o tridenthelper.o \
       trident_accel.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86OSSRC) -I$(SERVERSRC)/Xext \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/xaa \
           -I$(XF86SRC)/vgahw -I$(XF86SRC)/ramdac \
           -I$(FONTINCSRC) -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

ModuleObjectRule()

ObjectModuleTarget(trident,$(OBJS))

InstallLinkKitNonExecFile(trident.h,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/mga)

InstallObjectModule(trident,$(MODULEDIR))

DependTarget()

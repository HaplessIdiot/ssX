XCOMM
XCOMM This is an Imakefile for the MGA driver.  
XCOMM

#define IHaveModules
#include <Server.tmpl>

SRCS = mgadriver.c mga_initacc.c \
       mga_accel8.c mga_accel16.c mga_accel24.c mga_accel32.c
OBJS = mgadriver.o mga_initacc.o \
       mga_accel8.o mga_accel16.o mga_accel24.o mga_accel32.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/vga256/vga -I$(XF86SRC)/xaa \
           -I$(FONTINCSRC) -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()
NormalRelocatableTarget(mga_drv, $(OBJS))

ObjectFromSpecialSource(mga_accel8, mga_accel, -DPSZ=8)
ObjectFromSpecialSource(mga_accel16, mga_accel, -DPSZ=16)
ObjectFromSpecialSource(mga_accel24, mga_accel, -DPSZ=24)
ObjectFromSpecialSource(mga_accel32, mga_accel, -DPSZ=32)

InstallLinkKitNonExecFile(mga.h,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mgabios.h,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mgareg.h,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mgadriver.c,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mga_initacc.c,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mga_accel.c,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(mga_map.h,$(LINKKITDIR)/drivers/mga)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/mga)

#if DoLoadableServer
InstallDynamicModule(mga_drv.o,$(MODULEDIR))
#endif

DependTarget()

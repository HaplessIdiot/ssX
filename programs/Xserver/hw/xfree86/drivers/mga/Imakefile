XCOMM This is an Imakefile for the MGA driver.  
XCOMM

#define IHaveModules
#include <Server.tmpl>

SRCS = mga_driver.c mga_hwcurs.c /* mga_cmap.c */ mga_dac3026.c mga_dacG.c \
       mga_storm8.c mga_storm16.c mga_storm24.c mga_storm32.c mga_arc.c
OBJS = mga_driver.o mga_hwcurs.o /* mga_cmap.o */ mga_dac3026.o mga_dacG.o \
       mga_storm8.o mga_storm16.o mga_storm24.o mga_storm32.o mga_arc.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/xaa \
           -I$(XF86SRC)/vgahw -I$(XF86SRC)/ramdac \
           -I$(XF86SRC)/ddc -I$(XF86SRC)/i2c \
           -I$(SERVERSRC)/Xext \
           -I$(FONTINCSRC) -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

ModuleObjectRule()

ObjectModuleTarget(mga,$(OBJS))

ObjectFromSpecialSource(mga_storm8, mga_storm, -DPSZ=8)
ObjectFromSpecialSource(mga_storm16, mga_storm, -DPSZ=16)
ObjectFromSpecialSource(mga_storm24, mga_storm, -DPSZ=24)
ObjectFromSpecialSource(mga_storm32, mga_storm, -DPSZ=32)
  
InstallLinkKitNonExecFile(mga.h,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_bios.h,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_reg.h,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_driver.c,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_hwcurs.c,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_storm.c,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_map.h,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_dac3026.c,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(mga_dac1064.c,$(LINKKITDIR)/drivers/svga/mga)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/mga)

InstallObjectModule(mga,$(MODULEDIR))

DependTarget()

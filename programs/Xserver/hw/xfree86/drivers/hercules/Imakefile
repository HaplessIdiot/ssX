#include <Server.tmpl>

SRCS = herc_driver.c

OBJS = herc_driver.o 

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86SRC)/mono/mono -I$(XF86COMSRC) -I$(XF86HWSRC) \
	   -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/include \
           -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()

NormalRelocatableTarget(herc_drv, $(OBJS))

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/hercules)
InstallLinkKitNonExecFile(herc_driver.c,$(LINKKITDIR)/drivers/svga/hercules)

#if DoLoadableServer
InstallDynamicModule(herc_drv.o,$(MODULEDIR))
#endif

DependTarget()

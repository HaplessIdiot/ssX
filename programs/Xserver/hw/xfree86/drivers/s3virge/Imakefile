#define IHaveModules
#include <Server.tmpl>

SRCS = s3v_driver.c s3v_accel.c s3v_dac.c s3v_hwcurs.c

OBJS = s3v_driver.o s3v_accel.o s3v_dac.o s3v_hwcurs.o

DEFINES = -DPSZ=8
#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../.. -I../../../xaa
#else

INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/xaa \
           -I$(XF86SRC)/xf1bpp -I$(XF86SRC)/xf4bpp \
           -I$(XF86SRC)/xf24_32bpp -I$(SERVERSRC)/Xext \
           -I$(XF86SRC)/vgahw -I$(XF86SRC)/ramdac \
	   -I$(XF86SRC)/ddc -I$(XF86SRC)/i2c \
           -I$(SERVERSRC)/include -I$(XINCLUDESRC) -I$(FONTINCSRC) \
           -I$(EXTINCSRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif

NormalAsmObjectRule()

ModuleObjectRule()
ObjectModuleTarget(s3virge, $(OBJS))

InstallObjectModule(s3virge,$(MODULEDIR),drivers)

CppManTarget(s3virge,)
InstallModuleManPage(s3virge)

DependTarget()

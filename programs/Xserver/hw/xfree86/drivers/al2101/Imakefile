#define IHaveModules
#include <Server.tmpl>

SRCS = al_driver.c al_bank.s

OBJS = al_driver.o al_bank.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(XF86SRC)/vga256/vga -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(al_drv, $(OBJS))

InstallLinkKitNonExecFile(al_driver.c,$(LINKKITDIR)/drivers/svga/al2101)
InstallLinkKitNonExecFile(al_bank.s,$(LINKKITDIR)/drivers/svga/al2101)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/al2101)

#if DoLoadableServer
InstallDynamicModule(al_drv.o,$(MODULEDIR))
#endif

DependTarget()

#include <Server.tmpl>

SRCS = hgc1280_driver.c

OBJS = hgc1280_driver.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86SRC)/mono/mono -I$(XF86COMSRC) -I$(XF86HWSRC) \
	   -I$(XF86OSSRC) \
	   -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/include \
	   -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()

NormalRelocatableTarget(hgc1280_drv, $(OBJS))

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/hgc1280)
InstallLinkKitNonExecFile(hgc1280HW.h,$(LINKKITDIR)/drivers/hgc1280)
InstallLinkKitNonExecFile(hgc1280_driver.c,$(LINKKITDIR)/drivers/hgc1280)
InstallLinkKitNonExecFile(HGC1280.info,$(LINKKITDIR)/drivers/hgc1280)

#if DoLoadableServer
InstallDynamicModule(hgc1280_drv.o,$(MODULEDIR))
#endif

DependTarget()

#include <Server.tmpl>

SRCS = apollo_driver.c apolloBlt.c

OBJS = apollo_driver.o apolloBlt.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86SRC)/mono/mono -I$(XF86COMSRC) -I$(XF86HWSRC) \
	   -I$(XF86OSSRC) \
	   -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/include \
	   -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()

NormalRelocatableTarget(apollo_drv, $(OBJS))

InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/apollo)
InstallLinkKitNonExecFile(apolloHW.h,$(LINKKITDIR)/drivers/svga/apollo)
InstallLinkKitNonExecFile(apollo_driver.c,$(LINKKITDIR)/drivers/svga/apollo)
InstallLinkKitNonExecFile(apolloBlt.c,$(LINKKITDIR)/drivers/svga/apollo)

#if DoLoadableServer
InstallDynamicModule(apollo_drv.o,$(MODULEDIR))
#endif

DependTarget()


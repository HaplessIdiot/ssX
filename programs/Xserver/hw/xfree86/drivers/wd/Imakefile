XCOMM $XFree86: $



#define IHaveModules
#include <Server.tmpl>

SRCS = wd_driver.c pvg_bank.s pvgablt.c pvgasolid.c pvgaBitBlt.c \
       pvgapntwin.c

OBJS = wd_driver.o pvg_bank.o pvgablt.o pvgasolid.o pvgaBitBlt.o \
       pvgapntwin.o

DEFINES = -DPSZ=8

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/cfb -I$(SERVERSRC)/mfb \
           -I$(SERVERSRC)/mi -I$(XF86SRC)/vga256/vga -I$(SERVERSRC)/include \
	   -I$(XINCLUDESRC) -I$(FONTINCSRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(wd_drv,$(OBJS))

ObjectFromSpecialAsmSource(pvg_bank,bank,NullParameter)

InstallLinkKitNonExecFile(paradise.h,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(wd_driver.c,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(bank.s,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(pvgablt.c,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(pvgasolid.c,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(pvgaBitBlt.c,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(pvgapntwin.c,$(LINKKITDIR)/drivers/wd)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/wd)

#if DoLoadableServer
InstallDynamicModule(wd_drv.o,$(MODULEDIR))
#endif

DependTarget()

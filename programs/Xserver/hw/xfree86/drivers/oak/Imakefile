XCOMM $XFree86: $



#define IHaveModules
#include <Server.tmpl>

SRCS = oak_driver.c oak_bank.s oti87_fill.c oti87_sol.c oti87_bltC.c \
       oak_colexp.s

OBJS = oak_driver.o oak_bank.o oti87_fill.o oti87_sol.o oti87_bltC.o \
       oak_colexp.o

DEFINES = -DPSZ=8

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/cfb \
           -I$(XF86SRC)/vga256/vga -I$(FONTINCSRC) \
           -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(oak_drv,$(OBJS))

InstallLinkKitNonExecFile(oak_driver.c,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oak_driver.h,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oak_bank.s,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oti87_fill.c,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oti87_sol.c,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oti87_bltC.c,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(oak_colexp.s,$(LINKKITDIR)/drivers/oak)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/oak)

#if DoLoadableServer
InstallDynamicModule(oak_drv.o,$(MODULEDIR))
#endif

DependTarget()

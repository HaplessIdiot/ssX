#define IHaveModules
#include <Server.tmpl>

SRCS = ark_driver.c ark_bank.s ark_cursor.c ark_bitblt.c ark_blt16.c \
	ark_accel.c

OBJS = ark_driver.o ark_bank.o ark_cursor.o ark_bitblt.o ark_blt16.o \
	ark_accel.o

DEFINES = -DPSZ=8

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
           -I$(SERVERSRC)/cfb -I$(XF86SRC)/vga256/vga -I$(XF86SRC)/xaa \
           -I$(FONTINCSRC) -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()
NormalAsmObjectRule()

NormalRelocatableTarget(ark_drv,$(OBJS))

InstallLinkKitNonExecFile(ark_driver.c,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_driver.h,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_bank.s,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_cop.h,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_cursor.c,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_cursor.h,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_bitblt.c,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_blt16.c,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(ark_accel.c,$(LINKKITDIR)/drivers/svga/ark)
InstallLinkKitNonExecFile(Imakefile,$(LINKKITDIR)/drivers/svga/ark)

#if DoLoadableServer
InstallDynamicModule(ark_drv.o,$(MODULEDIR))
#endif

DependTarget()

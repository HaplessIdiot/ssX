LinkSourceFile(p9000init.c, P9000LinkDirectory)
LinkSourceFile(p9000viper.c, P9000LinkDirectory)
LinkSourceFile(p9000BtCurs.c, P9000LinkDirectory)
LinkSourceFile(p9000Bt485.c, P9000LinkDirectory)
LinkSourceFile(p9000vga.c, P9000LinkDirectory)
LinkSourceFile(p9000scrin.c, P9000LinkDirectory)
LinkSourceFile(p9000curs.c, P9000LinkDirectory)
LinkSourceFile(ICD2061Aset.c, P9000LinkDirectory)
LinkSourceFile(ICD2061Acal.c, P9000LinkDirectory)
LinkSourceFile(p9000bank.s, P9000LinkDirectory)

InstallLinkKitLibrary(p9000bank,$(LINKKITDIR)/drivers)

DependTarget()

#define IHaveModules
#include <Server.tmpl>

SRCS = xf86Wacom.c
OBJS = xf86Wacom.o

DRIVER = wacom

INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86SRC)/loader -I$(XF86OSSRC) \
         -I$(SERVERSRC)/include -I$(SERVERSRC)/mi -I$(XINCLUDESRC) -I$(EXTINCSRC)

#if MakeHasPosixVariableSubstitutions

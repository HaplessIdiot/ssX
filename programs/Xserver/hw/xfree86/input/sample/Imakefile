install:: $(DRIVER).Osuf
	MakeDir($(DESTDIR)$(MODULEDIR))
	$(INSTALL) $(INSTALLFLAGS) $(INSTMODFLAGS) $(DRIVER).Osuf $(DESTDIR)$(MODULEDIR)


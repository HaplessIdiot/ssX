#define IHaveModules
#include <Server.tmpl>

#ifdef i386Architecture
VGABANKSRCS = vgaLBank.s
VGABANKOBJS = vgaLBank.o
#else
VGABANKSRCS = vgaLBankc.c
VGABANKOBJS = vgaLBankc.o
#endif

SRCS = 	$(VGABANKSRCS)

OBJS = 	$(VGABANKOBJS)

INCLUDES = -I$(XF86COMSRC) -I$(XF86OSSRC) -I$(XF86HWSRC) -I../../vga256/vga \
           -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi \
	   -I$(SERVERSRC)/cfb -I$(SERVERSRC)/include -I$(XINCLUDESRC) \
	   -I$(XF86SRC)/xaa -I$(FONTINCSRC)

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()
NormalAsmObjectRule()

#if XF86Vga2Banked
BANKEDDEFINES = -DBANKEDMONOVGA -DPSZ=1
#endif
DEFINES = -DMONOVGA -DXF86MONOVGA $(BANKEDDEFINES)

DependTarget()

#include <Server.tmpl>

SRCS = gen_driver.c

OBJS = gen_driver.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I../../../vga256/vga -I$(SERVERSRC)/include -I$(INCLUDESRC)
#endif

DEFINES = -DMONOVGA

NormalLibraryObjectRule()


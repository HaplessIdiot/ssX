	   -I$(SERVERSRC)/mi -I$(SERVERSRC)/include  -I$(INCLUDESRC)

#if DirtyStartup
STARTUPDEFINES = -DDIRTY_STARTUP
#endif

DEFINES = $(STARTUPDEFINES)


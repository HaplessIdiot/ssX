OBJS = hgc1280driv.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../..
#else
INCLUDES = -I. -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I../../bdm -I$(SERVERSRC)/include -I$(INCLUDESRC)
#endif
#if HasGcc2

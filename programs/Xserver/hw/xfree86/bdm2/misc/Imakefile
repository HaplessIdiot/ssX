#include <Server.tmpl>

SRCS =   dixfonts.c mibitblt.c
OBJS =   dixfonts.o mibitblt.o

INCLUDES = -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/include \
           -I$(INCLUDESRC) -I$(FONTINCSRC)

DEFINES = -DXF86MONO -DXF86BDM2

NormalLibraryObjectRule()

NormalRelocatableTarget(bdm2misc, $(OBJS))

ObjectFromSpecialSource(dixfonts,$(SERVERSRC)/dix/dixfonts,/**/)
ObjectFromSpecialSource(mibitblt,$(SERVERSRC)/mi/mibitblt,/**/)

DependTarget()

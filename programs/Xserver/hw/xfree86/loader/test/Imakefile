#define IHaveModules
#include <Server.tmpl>

SRCS = testmod1.c testmod2.c testmod3.c

INCLUDES = -I. -I$(SERVERSRC)/include -I$(XINCLUDESRC)

ModuleObjectRule()

ObjectModuleTarget(test1,testmod1.o)
ObjectModuleTarget(test2,testmod2.o)
ObjectModuleTarget(test3,testmod3.o)

InstallObjectModule(test1,$(MODULEDIR))
InstallObjectModule(test2,$(MODULEDIR))
InstallObjectModule(test3,$(MODULEDIR))

DependTarget()

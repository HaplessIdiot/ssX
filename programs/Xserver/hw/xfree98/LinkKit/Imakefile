XCOMM $XConsortium: Imakefile /main/2 1995/12/29 11:20:36 kaleb $


all:: mkmf

CppScriptTarget(mkmf,mkmf.cpp,-DCONFIGDIRSPEC=-I$(CONFIGDIR),$(ICONFIGFILES))
InstallLinkKitNamedNonExec(Imakefile.LK,Imakefile,$(XF98LINKKITDIR))
InstallLinkKitNamedNonExec(site.def.LK,xf86site.def,$(XF98LINKKITDIR))
InstallLinkKitNamedProg(mkmf,mkmf,$(XF98LINKKITDIR))
#if !HasLinuxDoc
InstallLinkKitNonExecFile(README,$(XF98LINKKITDIR))
#ifndef DontInstallPC98Version
InstallNamedNonExec(README,README.LinkKit,$(XFREE86DOCDIR))
#endif
#endif

LinkSourceFile(Imakefile.LK,$(XF86SRC)/LinkKit)
LinkSourceFile(README,$(XF86SRC)/LinkKit)
LinkSourceFile(mkmf.cpp,$(XF86SRC)/LinkKit)
LinkSourceFile(site.def.LK,$(XF86SRC)/LinkKit)

DependTarget()

#include <Server.tmpl>

#define UseDBMalloc	NO

#if UseDBMalloc
SYS_LIBRARIES=-ldbmalloc
DBMALLOCDEFINE=-DDBMALLOC
#endif

#if HasDlopen
DEFINES = -DDLOPEN_SUPPORT
DLSRC=dlloader.c
DLOBJ=dlloader.o
#endif

MODULEDEFINES = -DDEFAULT_MODULE_PATH=\"$(MODULEDIR)\"

   INCLUDES = -I. -I.. -I$(XF86COMSRC) -I$(XF86OSSRC) -I$(XF86HWSRC) \
	      -I$(XF86SRC)/vga256/vga \
              -I$(SERVERSRC)/mfb -I$(SERVERSRC)/mi -I$(SERVERSRC)/include \
              -I$(SERVERSRC)/os -I$(XINCLUDESRC) -I$(FONTINCSRC) -I$(EXTINCSRC)

#ifdef OS2Architecture
SRCS1 = os2funcs.c
OBJS1 = os2funcs.o
#endif

SRCS = aoutloader.c coffloader.c $(DLSRC) elfloader.c hash.c loader.c \
	loadmod.c dixsym.c misym.c xf86sym.c $(SRCS1)
OBJS = aoutloader.o coffloader.o $(DLOBJ)  elfloader.o hash.o loader.o \
	loadmod.o dixsym.o misym.o xf86sym.o $(OBJS1)

NormalAsmObjectRule()

NormalLibraryObjectRule()
NormalLibraryTarget(loader,$(OBJS))

SpecialObjectRule(loadmod.o,loadmod.c,$(MODULEDEFINES) $(EXT_DEFINES))
SpecialObjectRule(xf86sym.o,xf86sym.c,$(EXT_DEFINES))
SpecialObjectRule(dixsym.o,dixsym.c,$(EXT_DEFINES))

LinkSourceFile(README,$(XF86SRC)/loader)
LinkSourceFile(aout.h,$(XF86SRC)/loader)
LinkSourceFile(aoutloader.c,$(XF86SRC)/loader)
LinkSourceFile(aoutloader.h,$(XF86SRC)/loader)
LinkSourceFile(ar.h,$(XF86SRC)/loader)
LinkSourceFile(coff.h,$(XF86SRC)/loader)
LinkSourceFile(coffloader.c,$(XF86SRC)/loader)
LinkSourceFile(coffloader.h,$(XF86SRC)/loader)
LinkSourceFile(dixsym.c,$(XF86SRC)/loader)
LinkSourceFile(dlloader.c,$(XF86SRC)/loader)
LinkSourceFile(elf.h,$(XF86SRC)/loader)
LinkSourceFile(elfloader.c,$(XF86SRC)/loader)
LinkSourceFile(elfloader.h,$(XF86SRC)/loader)
LinkSourceFile(hash.c,$(XF86SRC)/loader)
LinkSourceFile(hash.h,$(XF86SRC)/loader)
LinkSourceFile(loader.c,$(XF86SRC)/loader)
LinkSourceFile(loader.h,$(XF86SRC)/loader)
LinkSourceFile(loaderProcs.h,$(XF86SRC)/loader)
LinkSourceFile(loadmod.c,$(XF86SRC)/loader)
LinkSourceFile(misym.c,$(XF86SRC)/loader)
LinkSourceFile(os2funcs.c,$(XF86SRC)/loader)
LinkSourceFile(sym.h,$(XF86SRC)/loader)
LinkSourceFile(xf86sym.c,$(XF86SRC)/loader)

InstallLinkKitLibrary(loader,$(XF98LINKKITDIR)/drivers98)

DependTarget()

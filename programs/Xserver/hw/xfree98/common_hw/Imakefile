#include <Server.tmpl>
#define IHaveSubdirs

#if XF98NECS3Server || XF98NECS3Module
NECS3DIR = nec
#endif
#if XF98PWSKBServer || XF98PWSKBModule
PWSKBDIR = pwskb
#endif
#if XF98PWLBServer || XF98PWLBModule
PWLBDIR = pwlb
#endif
#if XF98GA968Server || XF98GA968Module
GA968DIR = ga968
#endif
#if XF98GANBWAPServer || XF98PEGCServer || XF98NKVNECServer || \
    XF98WABSServer    || XF98WABEPServer  || XF98WSNAServer   || \
    XF98TGUIServer    || XF98EGCServer || XF98LoaderServer || \
    XF98GANBWAPModule || XF98PEGCModule || XF98NKVNECModule || \
    XF98WABSModule    || XF98WABEPModule  || XF98WSNAModule   || \
    XF98TGUIModule    || XF98EGCModule
GENERICDIR = generic
#endif

SUBDIRS = $(NECS3DIR) $(PWSKBDIR) $(PWLBDIR) $(GA968DIR) $(GENERICDIR)

MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

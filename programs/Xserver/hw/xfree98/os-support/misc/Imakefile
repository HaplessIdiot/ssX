#include <Server.tmpl>

#if DoLoadableServer
DSRC = xf86dummy.c
DOBJ = xf86dummy.o 
#endif

SRCS = xf86_Util.c xf86_IlHack.c $(DSRC)

OBJS = xf86_Util.o xf86_IlHack.o $(DOBJ)

INCLUDES = -I$(XF86COMSRC) -I$(XF86OSSRC) -I$(XF86SRC)/config -I. \
	   -I$(SERVERSRC)/include -I$(XINCLUDESRC)

DEFINES = -DPC98

SubdirLibraryRule($(OBJS))
NormalLibraryObjectRule()

LinkSourceFile(xf86_IlHack.c,$(XF86OSSRC)/misc)
LinkSourceFile(xf86_Util.c,$(XF86OSSRC)/misc)
LinkSourceFile(xf86dummy.c,$(XF86OSSRC)/misc)

#if DoLoadableServer
InstallLinkKitNonExecFile(xf86dummy.o,$(XF98LINKKITDIR)/lib98)
#endif

DependTarget()

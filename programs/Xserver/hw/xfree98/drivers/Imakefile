MGAOBJS = mga/mga_drv.o
#endif

SUBDIRS = $(EGCDIR) $(GANBWAPDIR) $(PEGCDIR) $(NKVNECDIR) $(WABSDIR) \
	  $(WABEPDIR) $(WSNADIR) $(TGUIDIR) $(MGADIR)

#if 0
MakeSubdirs($(SUBDIRS))
#endif

#if MakeHasPosixVariableSubstitutions
DONES = $(SUBDIRS:%=%/DONE)
#if HasGnuMake || HasBsdMake
$(DONES): $(SUBDIRS)
#endif

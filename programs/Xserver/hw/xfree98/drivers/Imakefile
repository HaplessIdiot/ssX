GANBWAPOBJS = ganbwap/ganbwap_drv.o
#endif

#if XF98PEGCServer || XF98PEGCModule
PEGCDIR  = pegc
PEGCSRCS = pegc/?*.c
PEGCOBJS = pegc/pegc_drv.o
#endif

#if XF98NKVNECServer || XF98NKVNECModule

#include <Server.tmpl>

SRCS = vga_driver.c

OBJS = vga_driver.o

#if XF86LinkKit
INCLUDES = -I. -I../../../include -I../../../include/X11 -I../..
#else
INCLUDES = -I. -I$(XF86SRC) -I$(XF86COMSRC) -I$(XF86HWSRC) -I$(XF86OSSRC) \
           -I$(XF86SRC)/config -I$(XF86SRC)/vga256/vga \
	   -I$(SERVERSRC)/include -I$(XINCLUDESRC)
#endif

DEFINES = -DPC98 -DPC98_EGC

#if MakeHasPosixVariableSubstitutions
SubdirLibraryRule($(OBJS))
#endif
NormalLibraryObjectRule()

NormalRelocatableTarget(egc_drv, $(OBJS))

#if !XF86LinkKit
LinkSourceFile(vga_driver.c,$(XF86SRC)/drivers/vga)
#endif

InstallLinkKitNonExecFile(Imakefile,$(XF98LINKKITDIR)/drivers98/svga/egc)
InstallLinkKitNonExecFile(vga_driver.c,$(XF98LINKKITDIR)/drivers98/svga/egc)

#if DoLoadableServer
InstallDynamicModule(egc_drv.o,$(MODULEDIR))
#endif

DependTarget()

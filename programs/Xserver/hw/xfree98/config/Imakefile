#define DoNormalLib     YES
#define DoSharedLib     NO
#define DoDebugLib      NO
#define DoProfileLib    NO
#define HasSharedData   NO
#define LibName         xf86config

#define UseDBMalloc	NO

#if UseDBMalloc
SYS_LIBRARIES=-ldbmalloc
DBMALLOCDEFINE=-DDBMALLOC
#endif

XCONFIGFILE = XConfigFile
XCONFIGDIR = XConfigDir

INCLUDES = -I. -I$(XF86OSSRC)

HEADERS = xf86Parser.h xf86Optrec.h xf86Symtabs.h

SRCS = Device.c Files.c Flags.c Keyboard.c Layout.c Module.c \
	Monitor.c Pointer.c Screen.c Vendor.c read.c scan.c write.c
OBJS = Device.o Files.o Flags.o Keyboard.o Layout.o Module.o \
	Monitor.o Pointer.o Screen.o Vendor.o read.o scan.o write.o

CONFIG_DEFINES = -DXCONFIGDIR=\"$(XCONFIGDIR)\" -DXCONFIGFILE=\"$(XCONFIGFILE)\"

#include <Library.tmpl>

SpecialObjectRule(scan.o,scan.c,$(CONFIG_DEFINES) $(MODULEDEFINES) $(EXT_DEFINES))

NormalProgramTarget(cpconfig,cpconfig.o $(OBJS),NullParameter,NullParameter,NullParameter)

InstallLinkKitLibrary(xf86config,$(LINKKITDIR)/drivers)

AllTarget(cpconfig)
DependTarget()

LinkSourceFile(Configint.h,$(XF86SRC)/config)
LinkSourceFile(Device.c,$(XF86SRC)/config)
LinkSourceFile(Files.c,$(XF86SRC)/config)
LinkSourceFile(Flags.c,$(XF86SRC)/config)
LinkSourceFile(Keyboard.c,$(XF86SRC)/config)
LinkSourceFile(Layout.c,$(XF86SRC)/config)
LinkSourceFile(Module.c,$(XF86SRC)/config)
LinkSourceFile(Monitor.c,$(XF86SRC)/config)
LinkSourceFile(Pointer.c,$(XF86SRC)/config)
LinkSourceFile(Screen.c,$(XF86SRC)/config)
LinkSourceFile(Vendor.c,$(XF86SRC)/config)
LinkSourceFile(configProcs.h,$(XF86SRC)/config)
LinkSourceFile(cpconfig.c,$(XF86SRC)/config)
LinkSourceFile(read.c,$(XF86SRC)/config)
LinkSourceFile(scan.c,$(XF86SRC)/config)
LinkSourceFile(write.c,$(XF86SRC)/config)
LinkSourceFile(xf86Optrec.h,$(XF86SRC)/config)
LinkSourceFile(xf86Parser.h,$(XF86SRC)/config)
LinkSourceFile(xf86Symtabs.h,$(XF86SRC)/config)
LinkSourceFile(xf86tokens.h,$(XF86SRC)/config)

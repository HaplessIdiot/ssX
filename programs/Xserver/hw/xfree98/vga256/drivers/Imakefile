XCOMM $XFree86$
#include <Server.tmpl>
#define IHaveSubdirs

#if XF98GANBWAPServer
GANBWAPDIR  = ganbwap
GANBWAPSRCS = ganbwap/?*.c
GANBWAPOBJS = ganbwap/?*_drv.o
#endif

#if XF98NEC480Server
NEC480DIR  = nec480
NEC480SRCS = nec480/?*.c
NEC480OBJS = nec480/?*_drv.o
#endif

#if XF98NKVNECServer
NKVNECDIR  = nkvnec
NKVNECSRCS = nkvnec/?*.c
NKVNECOBJS = nkvnec/?*_drv.o
#endif

#if XF98WABSServer
WABSDIR  = wabs
WABSSRCS = wabs/?*.c
WABSOBJS = wabs/?*_drv.o
#endif

#if XF98SVGAServer
SVGA98DIR  = generic
SVGA98SRCS = generic/?*.c
SVGA98OBJS = generic/?*_drv.o
#endif

SUBDIRS = $(GANBWAPDIR) $(NEC480DIR) $(NKVNECDIR) $(WABSDIR) $(SVGADIR)

#if XF98GANBWAPServer
NormalDepLibraryTarget(driverganbwap,$(GANBWAPDIR),$(GANBWAPOBJS))
#endif
#if XF98NEC480Server
NormalDepLibraryTarget(drivernec480,$(NEC480DIR),$(NEC480OBJS))
#endif
#if XF98NKVNECServer
NormalDepLibraryTarget(drivernkvnec,$(NKVNECDIR),$(NKVNECOBJS))
#endif
#if XF98WABSServer
NormalDepLibraryTarget(driverwabs,$(WABSDIR),$(WABSOBJS))
#endif
#if XF98SVGAServer
NormalDepLibraryTarget(driver256,$(SVGA98DIR),$(SVGA98OBJS))
#endif

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

DependSubdirs($(SUBDIRS))

#include <Server.tmpl>
#define IHaveSubdirs

#if XF98GANBWAPServer || XF98GANBWAPModule
GANBWAPDIR  = ganbwap
GANBWAPSRCS = ganbwap/?*.c
GANBWAPOBJS = ganbwap/ganbwap_drv.o
#endif

#if XF98PEGCServer || XF98PEGCModule
PEGCDIR  = pegc
PEGCSRCS = pegc/?*.c
PEGCOBJS = pegc/pegc_drv.o
#endif

#if XF98NKVNECServer || XF98NKVNECModule
NKVNECDIR  = nkvnec
NKVNECSRCS = nkvnec/?*.c
NKVNECOBJS = nkvnec/nkvnec_drv.o
#endif

#if XF98WABSServer || XF98WABSModule
WABSDIR  = wabs
WABSSRCS = wabs/?*.c
WABSOBJS = wabs/wabs_drv.o
#endif

#if XF98WABEPServer || XF98WABEPModule
WABEPDIR  = wabep
WABEPSRCS = wabep/?*.c
WABEPOBJS = wabep/wabep_drv.o
#endif

#if XF98WSNAServer || XF98WSNAModule
WSNADIR  = wsna
WSNASRCS = wsna/?*.c
WSNAOBJS = wsna/wsna_drv.o
#endif

#if XF98TGUIServer || XF98TGUIModule
TGUIDIR  = trident
TGUISRCS = trident/?*.c
TGUIOBJS = trident/tvga89_drv.o
#endif

SUBDIRS = $(GANBWAPDIR) $(PEGCDIR) $(NKVNECDIR) $(WABSDIR) $(WABEPDIR) \
	  $(WSNADIR) $(TGUIDIR)

#if XF98GANBWAPServer || XF98GANBWAPModule
NormalDepLibraryTarget(driverganbwap,$(GANBWAPDIR) $(GANBWAPOBJS),$(GANBWAPOBJS))
#endif
#if XF98PEGCServer || XF98PEGCModule
NormalDepLibraryTarget(driverpegc,$(PEGCDIR) $(PEGCOBJS),$(PEGCOBJS))
#endif
#if XF98NKVNECServer || XF98NKVNECModule
NormalDepLibraryTarget(drivernkvnec,$(NKVNECDIR) $(NKVNECOBJS),$(NKVNECOBJS))
#endif
#if XF98WABSServer || XF98WABSModule
NormalDepLibraryTarget(driverwabs,$(WABSDIR) $(WABSOBJS),$(WABSOBJS))
#endif
#if XF98WABEPServer || XF98WABEPModule
NormalDepLibraryTarget(driverwabep,$(WABEPDIR) $(WABEPOBJS),$(WABEPOBJS))
#endif
#if XF98WSNAServer || XF98WSNAModule
NormalDepLibraryTarget(driverwsna,$(WSNADIR) $(WSNAOBJS),$(WSNAOBJS))
#endif
#if XF98TGUIServer || XF98TGUIModule
NormalDepLibraryTarget(drivertrident,$(TGUIDIR) $(TGUIOBJS),$(TGUIOBJS))
#endif

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

DependSubdirs($(SUBDIRS))

InstallLinkKitNonExecFile(Imakefile,$(XF98LINKKITDIR)/drivers98/vga256)

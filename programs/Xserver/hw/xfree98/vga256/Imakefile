#endif
#if XF98WSNAServer || XF98WSNAModule
NormalDepLibraryTarget(wsna,$(WSNASUBDIRS) $(WSNADONES),$(WSNAOBJS))
#endif
#if XF98PEGCServer || XF98PEGCModule
NormalDepLibraryTarget(pegc,$(PEGCSUBDIRS) $(PEGCDONES),$(PEGCOBJS))
#endif
#if XF98NKVNECServer || XF98NKVNECModule
NormalDepLibraryTarget(nkvnec,$(NKVNECSUBDIRS) $(NKVNECDONES),$(NKVNECOBJS))
#endif
#if XF98WABSServer || XF98WABSModule
NormalDepLibraryTarget(wabs,$(WABSSUBDIRS) $(WABSDONES),$(WABSOBJS))
#endif
#if XF98WABEPServer || XF98WABEPModule
NormalDepLibraryTarget(wabep,$(WABEPSUBDIRS) $(WABEPDONES),$(WABEPOBJS))
#endif
#if XF98TGUIServer || XF98TGUIModule
NormalDepLibraryTarget(trident,$(TGUISUBDIRS) $(TGUIDONES),$(TGUIOBJS))
#endif
#if XF98SVGAServer || XF98SVGAModule
NormalDepLibraryTarget(vga256,$(SVGASUBDIRS) $(SVGADONES),$(SVGAOBJS))
#endif
#if XF98MGAServer || XF98MGAModule
NormalDepLibraryTarget(mga,$(MGASUBDIRS) $(MGADONES),$(MGAOBJS))
#endif
#if XF98EGCServer || XF98EGCModule
NormalDepLibraryTarget(egc,$(EGCSUBDIRS) $(EGCDONES),$(EGCOBJS))
#endif
#endif

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

InstallLinkKitLibrary(ganbwap,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(pegc,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(nkvnec,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(trident,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(mga,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wabep,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wabs,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wsna,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(vga256,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(egc,$(XF98LINKKITDIR)/drivers98)
#ifndef DontInstallPC98Version
InstallLinkKitNonExecFile(cvga256.SHsuf,$(XF98LINKKITDIR))
#endif
InstallLinkKitNonExecFile(cpegc.SHsuf,$(XF98LINKKITDIR))
InstallLinkKitNonExecFile(ctgui.SHsuf,$(XF98LINKKITDIR))
InstallLinkKitNonExecFile(cmga.SHsuf,$(XF98LINKKITDIR))
InstallLinkKitNonExecFile(cegc.SHsuf,$(XF98LINKKITDIR))


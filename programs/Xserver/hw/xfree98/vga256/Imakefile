#define IHaveModules
#include <Server.tmpl>

#define IHaveSubdirs

#if XF98GANBWAPServer || XF98GANBWAPModule
GANBWAPSUBDIRS = ganbwap 
GANBWAPSRCS    = ganbwap/?*.c
GANBWAPOBJS    = ganbwap/?*.o
GANBWAPDONES   = ganbwap/DONE
#endif

#if XF98PEGCServer || XF98PEGCModule
PEGCSUBDIRS = pegc
PEGCSRCS    = pegc/?*.c
PEGCOBJS    = pegc/?*.o
PEGCDONES   = pegc/DONE
#endif

#if XF98NKVNECServer || XF98NKVNECModule
NKVNECSUBDIRS = nkvnec
NKVNECSRCS    = nkvnec/?*.c
NKVNECOBJS    = nkvnec/?*.o
NKVNECDONES   = nkvnec/DONE
#endif

#if XF98WABSServer || XF98WABSModule
WABSSUBDIRS = wabs
WABSSRCS    = wabs/?*.c
WABSOBJS    = wabs/?*.o
WABSDONES   = wabs/DONE
#endif

#if XF98WABEPServer || XF98WABEPModule
WABEPSUBDIRS = wabep
WABEPSRCS    = wabep/?*.c
WABEPOBJS    = wabep/?*.o
WABEPDONES   = wabep/DONE
#endif

#if XF98WSNAServer || XF98WSNAModule
WSNASUBDIRS = wsna
WSNASRCS    = wsna/?*.c
WSNAOBJS    = wsna/?*.o
WSNADONES   = wsna/DONE
#endif

#if XF98TGUIServer || XF98TGUIModule
TGUISUBDIRS = trident

#endif
#if XF98WABEPServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98TGUIServer
ConfigTargetNoDepend(tguiConf,$(ICONFIGFILES),ctgui.SHsuf,trident)
#endif
#if XF98MGAServer
ConfigTargetNoDepend(mgaConf,$(ICONFIGFILES),cmga.SHsuf,mga)
#endif
#if XF98SVGAServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98EGCServer
ConfigTargetNoDepend(egcConf,$(ICONFIGFILES),cegc.SHsuf,egc)
#endif
#endif

#ifdef OS2Architecture
all:: DONE
	cp $(OBJS) .


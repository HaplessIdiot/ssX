#endif
#if XF98SVGAServer || XF98SVGAModule
NormalDepLibraryTarget(vga256,$(SVGASUBDIRS) $(SVGADONES),?*.o)
#endif
#if XF98EGCServer || XF98EGCModule
NormalDepLibraryTarget(egc,$(EGCSUBDIRS) $(EGCDONES),?*.o)
#endif
#else
#if XF98GANBWAPServer || XF98GANBWAPModule

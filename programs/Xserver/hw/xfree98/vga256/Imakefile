SVGADONES   = svga/DONE
#endif

#if XF98EGCServer || XF98EGCModule
EGCSUBDIRS = egc
EGCSRCS    = egc/?*.c
EGCOBJS    = egc/?*.o
EGCDONES   = egc/DONE
#endif

SUBDIRS = $(GANBWAPSUBDIRS) $(PEGCSUBDIRS) $(NKVNECSUBDIRS) \
	  $(WABSSUBDIRS) $(WABEPSUBDIRS) $(WSNASUBDIRS) $(TGUISUBDIRS) \
	  $(MGASUBDIRS) $(SVGASUBDIRS) $(EGCSUBDIRS)

SRCS    = $(GANBWAPSRCS) $(PEGCSRCS) $(NKVNECSRCS) $(WABSSRCS) \
	  $(WABEPSRCS) $(WSNASRCS) $(TGUISRCS) $(MGASRCS) $(SVGASRCS) \
          $(EGCSRCS)
OBJS    = $(GANBWAPOBJS) $(PEGCOBJS) $(NKVNECOBJS) $(WABSOBJS) \
	  $(WABEPOBJS) $(WSNAOBJS) $(TGUIOBJS) $(MGAOBJS) $(SVGAOBJS) \
          $(EGCOBJS)
DONES   = $(GANBWAPDONES) $(PEGCDONES) $(NKVNECDONES) $(WABSDONES) \
	  $(WABEPDONES) $(WSNADONES) $(TGUIDONES) $(MGADONES) $(SVGADONES) \
          $(EGCDONES)

INCLUDES = -I$(XF86SRC)/vga256/vga -I$(XF86COMSRC) -I$(XF86OSSRC) \
	   -I$(XF86SRC)/config -I$(SERVERSRC)/include -I$(XINCLUDESRC)

VGADRIVERS = XF98SvgaDrivers

$(GANBWAPDONES):	$(GANBWAPSUBDIRS)
$(PEGCDONES):	$(PEGCSUBDIRS)
$(NKVNECDONES):	$(NKVNECSUBDIRS)
$(WABSDONES):	$(WABSSUBDIRS)
$(WABEPDONES):	$(WABEPSUBDIRS)
$(WSNADONES):	$(WSNASUBDIRS)
$(TGUIDONES):	$(TGUISUBDIRS)
$(MGADONES):	$(MGASUBDIRS)
$(SVGADONES):	$(SVGASUBDIRS)
$(EGCDONES):	$(EGCSUBDIRS)

#if ! DoLoadableServer
#if XF98GANBWAPServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98WSNAServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98PEGCServer
ConfigTargetNoDepend(pegcConf,$(ICONFIGFILES),cpegc.SHsuf,pegc)
#endif
#if XF98NKVNECServer

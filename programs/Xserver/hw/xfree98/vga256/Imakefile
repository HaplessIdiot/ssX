#include <Server.tmpl>

#define IHaveSubdirs

#if XF98GANBWAPServer || XF98GANBWAPModule
GANBWAPSUBDIRS = ganbwap 
GANBWAPSRCS    = ganbwap/?*.c
GANBWAPOBJS    = ganbwap/?*.o
GANBWAPDONES   = ganbwap/DONE
#endif

#if XF98PEGCServer || XF98PEGCModule
PEGCSUBDIRS = pegc
PEGCSRCS    = pegc/?*.c
PEGCOBJS    = pegc/?*.o
PEGCDONES   = pegc/DONE
#endif

#if XF98NKVNECServer || XF98NKVNECModule
NKVNECSUBDIRS = nkvnec
NKVNECSRCS    = nkvnec/?*.c
NKVNECOBJS    = nkvnec/?*.o
NKVNECDONES   = nkvnec/DONE
#endif

#if XF98WABSServer || XF98WABSModule
WABSSUBDIRS = wabs
WABSSRCS    = wabs/?*.c
WABSOBJS    = wabs/?*.o
WABSDONES   = wabs/DONE
#endif

#if XF98WABEPServer || XF98WABEPModule
WABEPSUBDIRS = wabep
WABEPSRCS    = wabep/?*.c
WABEPOBJS    = wabep/?*.o
WABEPDONES   = wabep/DONE
#endif

#if XF98WSNAServer || XF98WSNAModule
WSNASUBDIRS = wsna
WSNASRCS    = wsna/?*.c
WSNAOBJS    = wsna/?*.o
WSNADONES   = wsna/DONE
#endif

#if XF98TGUIServer || XF98TGUIModule
TGUISUBDIRS = trident
TGUISRCS    = trident/?*.c
TGUIOBJS    = trident/?*.o
TGUIDONES   = trident/DONE
#endif

SUBDIRS = $(GANBWAPSUBDIRS) $(PEGCSUBDIRS) $(NKVNECSUBDIRS) \
	  $(WABSSUBDIRS) $(WABEPSUBDIRS) $(WSNASUBDIRS) $(TGUISUBDIRS)

SRCS    = $(GANBWAPSRCS) $(PEGCSRCS) $(NKVNECSRCS) $(WABSSRCS) \
	  $(WABEPSRCS) $(WSNASRCS) $(TGUISRCS)
OBJS    = $(GANBWAPOBJS) $(PEGCOBJS) $(NKVNECOBJS) $(WABSOBJS) \
	  $(WABEPOBJS) $(WSNAOBJS) $(TGUIOBJS)
DONES   = $(GANBWAPDONES) $(PEGCDONES) $(NKVNECDONES) $(WABSDONES) \
	  $(WABEPDONES) $(WSNADONES) $(TGUIDONES)

INCLUDES = -I$(XF86SRC)/vga256/vga -I$(XF86COMSRC) -I$(XF86OSSRC) \
	   -I$(SERVERSRC)/include -I$(XINCLUDESRC)

VGADRIVERS = XF98SvgaDrivers

#if HasParallelMake
MakeMutex($(SUBDIRS) $(OBJS) $(DONES))
#endif

#if HasGnuMake
$(DONES): $(SUBDIRS)
#endif

#if ! DoLoadableServer
#if XF98GANBWAPServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98WSNAServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98PEGCServer
ConfigTargetNoDepend(pegcConf,$(ICONFIGFILES),cpegc.SHsuf,pegc)
#endif
#if XF98NKVNECServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98WABSServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98WABEPServer
ConfigTargetNoDepend(vga256Conf,$(ICONFIGFILES),cvga256.SHsuf,cirrus)
#endif
#if XF98TGUIServer
ConfigTargetNoDepend(tguiConf,$(ICONFIGFILES),ctgui.SHsuf,trident)
#endif
#endif

#ifdef OS2Architecture
all:: DONE
	cp $(OBJS) .

#if XF98GANBWAPServer || XF98GANBWAPModule
NormalDepLibraryTarget(ganbwap,$(GANBWAPSUBDIRS) $(GANBWAPDONES),?*.o)
#endif
#if XF98WSNAServer || XF98WSNAModule
NormalDepLibraryTarget(wsna,$(WSNASUBDIRS) $(WSNADONES),?*.o)
#endif
#if XF98PEGCServer || XF98PEGCModule
NormalDepLibraryTarget(pegc,$(PEGCSUBDIRS) $(PEGCDONES),?*.o)
#endif
#if XF98NKVNECServer || XF98NKVNECModule
NormalDepLibraryTarget(nkvnec,$(NKVNECSUBDIRS) $(NKVNECDONES),?*.o)
#endif
#if XF98WABSServer || XF98WABSModule
NormalDepLibraryTarget(wabs,$(WABSSUBDIRS) $(WABSDONES),?*.o)
#endif
#if XF98WABEPServer || XF98WABEPModule
NormalDepLibraryTarget(wabep,$(WABEPSUBDIRS) $(WABEPDONES),?*.o)
#endif
#if XF98TGUIServer || XF98TGUIModule
NormalDepLibraryTarget(trident,$(TGUISUBDIRS) $(TGUIDONES),?*.o)
#endif
#else
#if XF98GANBWAPServer || XF98GANBWAPModule
NormalDepLibraryTarget(ganbwap,$(GANBWAPSUBDIRS) $(GANBWAPDONES),$(GANBWAPOBJS))
#endif
#if XF98WSNAServer || XF98WSNAModule
NormalDepLibraryTarget(wsna,$(WSNASUBDIRS) $(WSNADONES),$(WSNAOBJS))
#endif
#if XF98PEGCServer || XF98PEGCModule
NormalDepLibraryTarget(pegc,$(PEGCSUBDIRS) $(PEGCDONES),$(PEGCOBJS))
#endif
#if XF98NKVNECServer || XF98NKVNECModule
NormalDepLibraryTarget(nkvnec,$(NKVNECSUBDIRS) $(NKVNECDONES),$(NKVNECOBJS))
#endif
#if XF98WABSServer || XF98WABSModule
NormalDepLibraryTarget(wabs,$(WABSSUBDIRS) $(WABSDONES),$(WABSOBJS))
#endif
#if XF98WABEPServer || XF98WABEPModule
NormalDepLibraryTarget(wabep,$(WABEPSUBDIRS) $(WABEPDONES),$(WABEPOBJS))
#endif
#if XF98TGUIServer || XF98TGUIModule
NormalDepLibraryTarget(trident,$(TGUISUBDIRS) $(TGUIDONES),$(TGUIOBJS))
#endif
#endif

NormalLibraryObjectRule()

ForceSubdirs($(SUBDIRS))

InstallLinkKitLibrary(ganbwap,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(pegc,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(nkvnec,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(trident,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wabep,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wabs,$(XF98LINKKITDIR)/drivers98)
InstallLinkKitLibrary(wsna,$(XF98LINKKITDIR)/drivers98)
#ifndef DontInstallPC98Version
InstallLinkKitNonExecFile(cvga256.SHsuf,$(XF98LINKKITDIR))
#endif
InstallLinkKitNonExecFile(cpegc.SHsuf,$(XF98LINKKITDIR))
InstallLinkKitNonExecFile(ctgui.SHsuf,$(XF98LINKKITDIR))

#if DoLoadableServer
#if XF98GANBWAPModule
InstallDynamicModule(LibraryTargetName(ganbwap),$(MODULEDIR))
#endif
#if XF98PEGCModule
InstallDynamicModule(LibraryTargetName(pegc),$(MODULEDIR))
#endif
#if XF98NKVNECModule
InstallDynamicModule(LibraryTargetName(nkvnec),$(MODULEDIR))
#endif
#if XF98TGUIModule
#ifndef DontInstallPC98Version
InstallDynamicModule(LibraryTargetName(trident),$(MODULEDIR))
#endif
#endif
#if XF98WABEPModule
InstallDynamicModule(LibraryTargetName(wabep),$(MODULEDIR))
#endif
#if XF98WABSModule
InstallDynamicModule(LibraryTargetName(wabs),$(MODULEDIR))
#endif
#if XF98WSNAModule
InstallDynamicModule(LibraryTargetName(wsna),$(MODULEDIR))
#endif
#endif

DependSubdirs($(SUBDIRS))

#define IHaveModules
#include <Server.tmpl>

       SRCS = dbe.c midbe.c
       OBJS = dbe.o midbe.o
   INCLUDES = -I../include -I$(XINCLUDESRC) -I$(EXTINCSRC) -I$(EXTRAINCLUDES)
   LINTLIBS = ../dix/llib-ldix.ln ../os/llib-los.ln


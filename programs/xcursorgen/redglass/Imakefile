
#define CursorSources(name) name-16.png name-24.png name-32.png name-48.png name-64.png

ICONDIR=$(LIBDIR)/icons
THEME=redglass
THEMEDIR=$(ICONDIR)/$(THEME)/cursors

#define CursorShareTarget(name,orig)					@@\
all:: name								@@\
									@@\
name: orig.cfg CursorSources(orig)					@@\
	$(XCURSORGEN) orig.cfg name					@@\
									@@\
clean::									@@\
	$(RM) name							@@\
									@@\
InstallTarget(install,name,$(INSTDATAFLAGS),$(THEMEDIR))

#define CursorTarget(name) CursorShareTarget(name,name)


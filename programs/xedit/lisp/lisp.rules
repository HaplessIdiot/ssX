#define GperfLispFile(dep,file,flags)					@@\
dep.c:	file.c								@@\
									@@\
file.c: file.gperf							@@\
	RemoveFile($@)							@@\
	$(GPERF) flags $? > $@						@@\
									@@\
depend::								@@\
									@@\
clean::									@@\
	RemoveFile(file.c)

#ifndef LispModuleTarget
#define LispModuleTarget(module,liblist,options)			@@\
AllTarget(module.so)							@@\
									@@\
module.o: module.c							@@\
	RemoveFile($@)							@@\
	$(CC) -c $(CFLAGS) options -o $@ $?				@@\
									@@\
module.so: module.o							@@\
	RemoveFile($@)							@@\
	$(CC) -o $@ $(SHLIBLDFLAGS) $? $(LDOPTIONS) liblist $(EXTRA_LOAD_FLAGS) @@\
									@@\
clean:: 								@@\
	RemoveFile(module.o)						@@\
	RemoveFile(module.so)
#endif

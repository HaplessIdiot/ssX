#define IHaveSubdirs
#define PassCDebugFlags CDEBUGFLAGS="$(CDEBUGFLAGS)"

#if !BuildServersOnly
PROXYDIR = lbxproxy
#endif

#if !BuildLBXProxyOnly
XSERVERDIR = Xserver
#endif

SUBDIRS = $(XSERVERDIR) $(PROXYDIR)

#if HasParallelMake
MakeMutex($(SUBDIRS))
#endif

MakeSubdirs($(SUBDIRS))
DependSubdirs($(SUBDIRS))

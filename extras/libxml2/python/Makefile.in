@WITH_PYTHON_TRUE@all: _libxml.so libxml2.py

@WITH_PYTHON_TRUE@libxml2.py: $(srcdir)/libxml.py libxml2class.py
@WITH_PYTHON_TRUE@	cat $(srcdir)/libxml.py libxml2class.py > libxml2.py

@WITH_PYTHON_TRUE@_libxml.so: libxml.o libxml2-py.o types.o
@WITH_PYTHON_TRUE@	$(CC) $(LINK_FLAGS) libxml.o libxml2-py.o types.o $(LIBS) -o _libxml.so

@WITH_PYTHON_TRUE@install-data-local:
@WITH_PYTHON_TRUE@	$(mkinstalldirs) $(DESTDIR)$(PYTHON_SITE_PACKAGES)
@WITH_PYTHON_TRUE@	-@INSTALL@ -m 0644 libxml2.py $(DESTDIR)$(PYTHON_SITE_PACKAGES)
@WITH_PYTHON_TRUE@	-@INSTALL@ -m 0755 _libxml.so $(DESTDIR)$(PYTHON_SITE_PACKAGES)
@WITH_PYTHON_TRUE@	$(mkinstalldirs) $(DESTDIR)$(DOCS_DIR)
@WITH_PYTHON_TRUE@	-@(for doc in $(DOCS) ; \
@WITH_PYTHON_TRUE@	   do @INSTALL@ -m 0644 $$doc $(DESTDIR)$(DOCS_DIR) ; done)

@WITH_PYTHON_TRUE@libxml.o: libxml.c libxml2-export.c libxml_wrap.h
@WITH_PYTHON_TRUE@	$(CC) $(SHCFLAGS) -c -o libxml.o $(srcdir)/libxml.c

@WITH_PYTHON_TRUE@types.o: types.c libxml_wrap.h
@WITH_PYTHON_TRUE@	$(CC) $(SHCFLAGS) -c -o types.o $(srcdir)/types.c

@WITH_PYTHON_TRUE@libxml2-py.o: libxml2-py.c libxml2-py.h libxml_wrap.h
@WITH_PYTHON_TRUE@	$(CC) $(SHCFLAGS) -c -o libxml2-py.o $(srcdir)/libxml2-py.c

@WITH_PYTHON_TRUE@$(GENERATED): $(srcdir)/$(GENERATE) $(API_DESC)
@WITH_PYTHON_TRUE@	cd $(srcdir) && $(PYTHON) $(GENERATE)
@WITH_PYTHON_FALSE@all: 

tests: all
	cd tests && $(MAKE) tests

clean:
	rm -f $(GENERATED) *.o _libxml.so *.pyc libxml2.py


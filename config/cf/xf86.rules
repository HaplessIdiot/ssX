XCOMM $XFree86: xc/config/cf/xf86.rules,v 3.9 1995/07/12 15:27:38 dawes Exp $

/*
 * These rules are needed to build the Xfree86 X Servers
 */

#ifndef CPPOnlyAsm
#define CPPOnlyAsm(basename,options) RemoveFile(basename.i)		@@\
	$(CPP) AsmDefines $(DEFINES) $(INCLUDES) options basename.s | \	@@\
		grep -v '^\#' > basename.i
#endif

#ifndef AssembleObject
#define AssembleObject(flags) CPPOnlyAsm($*,flags)			@@\
	$(AS) -o $*.o $*.i						@@\
	RemoveFile($*.i)
#endif

#ifndef NormalAsmObjectRule
#define NormalAsmObjectRule()						@@\
.s.o:									@@\
	AssembleObject($(_NOOP_))					@@\
									@@\
.s.i:									@@\
	CPPOnlyAsm($*,$(_NOOP_))
#endif

#ifndef ObjectFromSpecialAsmSource
#define ObjectFromSpecialAsmSource(dst,src,flags)			@@\
dst.s:  src.s								@@\
	RemoveFile($@)							@@\
	$(LN) $? $@							@@\
									@@\
dst.o:  dst.s								@@\
	AssembleObject(flags)						@@\
									@@\
dst.i:  dst.s								@@\
	CPPOnlyAsm(dst,flags)						@@\
									@@\
depend:: dst.s								@@\
									@@\
clean::									@@\
	RemoveFile(dst.s)
#endif

#ifndef ObjectMapIncludeFromSpecialSource
#define ObjectMapIncludeFromSpecialSource(dst,src,flags)		@@\
dst.c:	src.c								@@\
	RemoveFile($@)							@@\
	echo "#include \"mfbmap.h\"" > $@				@@\
	echo "#include \"$?\"" >> $@					@@\
									@@\
SpecialCObjectRule(dst,NullParameter,flags)				@@\
									@@\
depend::	dst.c							@@\
									@@\
clean::									@@\
	RemoveFile(dst.c)
#endif


#ifndef CPPOnlyAsmWABS
#define CPPOnlyAsmWABS(basename,options) RemoveFile(basename.i)		 @@\
	$(CPP) AsmDefines $(DEFINES) $(INCLUDES) options basename.s | \	 @@\
	sed -f TOPDIR/programs/Xserver/hw/xfree98/common/98WAB.sed  | \  @@\
		grep -v '^\#' > basename.i
#endif

#ifndef AssembleObjectWABS
#define AssembleObjectWABS(flags) CPPOnlyAsmWABS($*,flags)		@@\
	$(AS) -o $*.o $*.i						@@\
	RemoveFile($*.i)
#endif

#ifndef NormalAsmObjectRuleWABS
#define NormalAsmObjectRuleWABS()					@@\
.s.o:									@@\
	AssembleObjectWABS($(_NOOP_))					@@\
									@@\
.s.i:									@@\
	CPPOnlyAsmWABS($*,$(_NOOP_))
#endif

#ifndef ObjectFromSpecialAsmSourceWABS
#define ObjectFromSpecialAsmSourceWABS(dst,src,flags)			@@\
dst.s:  src.s								@@\
	RemoveFile($@)							@@\
	$(LN) $? $@							@@\
									@@\
dst.o:  dst.s								@@\
	AssembleObjectWABS(flags)					@@\
									@@\
dst.i:  dst.s								@@\
	CPPOnlyAsmWABS(dst,flags)					@@\
									@@\
depend:: dst.s								@@\
									@@\
clean::									@@\
	RemoveFile(dst.s)
#endif

